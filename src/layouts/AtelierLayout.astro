---
interface Props {
  title?: string;
  description?: string;
  activeNav?: 'photography' | 'projects' | 'blog' | 'samling';
}

const {
  title = 'Ethan Reimann',
  description = 'The personal website of Ethan Reimann',
  activeNav
} = Astro.props;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Karla:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #fafaf8;
      --surface: #ffffff;
      --ink: #1c1917;
      --muted: #78716c;
      --border: #e7e5e0;
      --warm: #b45309;
      --warm-light: rgba(180, 83, 9, 0.06);
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Karla', sans-serif;
      font-size: clamp(0.9rem, 0.8rem + 0.4vw, 1.05rem);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: var(--warm); color: white; }

    .page { max-width: 900px; margin: 0 auto; padding: 0 2rem; }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 2.5rem 0;
      gap: 1rem;
      position: relative;
      z-index: 25;
      isolation: isolate;
    }
    .logo {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
      position: relative;
      z-index: 3;
    }
    .logo a { color: var(--ink); text-decoration: none; }
    .header-nav-wrap {
      display: flex;
      align-items: center;
      margin-left: auto;
      position: relative;
      z-index: 3;
    }
    .header-nav {
      display: flex;
      gap: 1.5rem;
      list-style: none;
      align-items: center;
    }
    .header-nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 400;
      transition: color 0.2s;
    }
    .header-nav a:hover { color: var(--ink); }
    .header-nav a.nav-active { color: var(--ink); font-weight: 500; }
    .nav-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      border: none;
      border-radius: 999px;
      background: transparent;
      color: var(--ink);
      width: 2.75rem;
      height: 2.75rem;
      font: inherit;
      cursor: pointer;
      flex: 0 0 2.75rem;
      transition: background-color 0.2s, color 0.2s;
    }
    .nav-toggle:hover {
      background: var(--warm-light);
      color: var(--warm);
    }
    .nav-toggle:focus-visible,
    .mobile-nav a:focus-visible {
      outline: 2px solid var(--warm);
      outline-offset: 3px;
    }
    .nav-toggle-icon {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.26rem;
      width: 1.15rem;
    }
    .nav-toggle-icon span {
      display: block;
      width: 100%;
      height: 2px;
      background: currentColor;
      border-radius: 999px;
      transform-origin: center;
      transition: transform 0.2s, opacity 0.2s;
    }
    .mobile-nav {
      display: none;
      width: min(16.5rem, calc(100vw - 2rem));
      margin-top: 0;
      border: 2px solid var(--ink);
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(250, 250, 248, 0.98), rgba(255, 255, 255, 0.96)),
        var(--surface);
      box-shadow: 0 18px 40px rgba(28, 25, 23, 0.12);
      overflow: hidden;
      position: absolute;
      top: calc(100% - 0.35rem);
      right: 0;
      z-index: 4;
      opacity: 0;
      max-height: 0;
      transform: translateY(-0.5rem) scale(0.96);
      transform-origin: top right;
      pointer-events: none;
      visibility: hidden;
      transition:
        opacity 0.24s ease,
        transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
        max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s linear 0.28s;
    }
    .mobile-nav-inner {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
      padding: 0.65rem;
    }
    .mobile-nav a {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0.1rem;
      min-height: 4.8rem;
      padding: 0.8rem 0.85rem;
      border-radius: 12px;
      color: var(--ink);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      background: transparent;
      line-height: 1.25;
      transition: background-color 0.2s, color 0.2s, transform 0.2s;
    }
    .mobile-nav a::after {
      content: 'Open';
      margin-top: auto;
      color: var(--muted);
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: transform 0.2s, color 0.2s;
    }
    .mobile-nav a:hover,
    .mobile-nav a.nav-active {
      background: var(--warm-light);
      color: var(--warm);
    }
    .mobile-nav a:hover::after,
    .mobile-nav a.nav-active::after {
      color: var(--warm);
      transform: translate(2px, -2px);
    }

    body[data-mobile-nav-open='true'] {
      overflow: hidden;
    }

    body[data-mobile-nav-open='true'] .nav-toggle-icon span:nth-child(1) {
      transform: translateY(0.36rem) rotate(45deg);
    }
    body[data-mobile-nav-open='true'] .nav-toggle-icon span:nth-child(2) {
      opacity: 0;
    }
    body[data-mobile-nav-open='true'] .nav-toggle-icon span:nth-child(3) {
      transform: translateY(-0.36rem) rotate(-45deg);
    }
    body[data-mobile-nav-open='true'] .mobile-nav {
      opacity: 1;
      max-height: 18rem;
      transform: translateY(0) scale(1);
      pointer-events: auto;
      visibility: visible;
      transition:
        opacity 0.24s ease,
        transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
        max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s linear 0s;
    }

    @media (max-width: 720px) {
      .page { padding: 0 1rem; }
      .header {
        align-items: center;
        flex-wrap: nowrap;
        padding: 1.25rem 0 1rem;
      }
      .header-nav-wrap {
        margin-left: auto;
      }
      .header-nav-wrap nav {
        display: none;
      }
      .nav-toggle {
        display: inline-flex;
      }
      .mobile-nav {
        display: block;
      }
    }

    @media (max-width: 420px) {
      .mobile-nav {
        width: min(14rem, calc(100vw - 2rem));
      }
      .mobile-nav-inner {
        grid-template-columns: 1fr;
      }
      .mobile-nav a {
        min-height: auto;
      }
    }

    @media (min-width: 721px) {
      body[data-mobile-nav-open='true'] {
        overflow: auto;
      }
    }

    /* Footer */
    .footer {
      padding: 2rem 0;
      border-top: 1px solid var(--border);
      text-align: center;
      color: var(--muted);
      font-size: 0.8rem;
    }
    .footer a { color: var(--warm); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .f { animation: fadeUp 0.65s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .f1 { animation-delay: 0.05s; } .f2 { animation-delay: 0.1s; }
    .f3 { animation-delay: 0.18s; } .f4 { animation-delay: 0.26s; }
    .f5 { animation-delay: 0.34s; } .f6 { animation-delay: 0.42s; }
    .f7 { animation-delay: 0.5s; }
  </style>
  <slot name="head" />
</head>
<body>
  <div class="page">
    <header class="header f f1">
      <div class="logo"><a href="/">Ethan Reimann</a></div>
      <div class="header-nav-wrap">
        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Open navigation menu"
          data-nav-toggle
        >
          <span class="nav-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
        <nav aria-label="Primary">
          <ul class="header-nav">
            <li><a href="/photography/" class={activeNav === 'photography' ? 'nav-active' : ''}>Photography</a></li>
            <li><a href="/projects/" class={activeNav === 'projects' ? 'nav-active' : ''}>Projects</a></li>
            <li><a href="/blog/" class={activeNav === 'blog' ? 'nav-active' : ''}>Blog</a></li>
            <li><a href="/samling/" class={activeNav === 'samling' ? 'nav-active' : ''}>Samling</a></li>
          </ul>
        </nav>
      </div>
      <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
        <div class="mobile-nav-inner">
          <a href="/photography/" class={activeNav === 'photography' ? 'nav-active' : ''}>Photography</a>
          <a href="/projects/" class={activeNav === 'projects' ? 'nav-active' : ''}>Projects</a>
          <a href="/blog/" class={activeNav === 'blog' ? 'nav-active' : ''}>Blog</a>
          <a href="/samling/" class={activeNav === 'samling' ? 'nav-active' : ''}>Samling</a>
        </div>
      </nav>
    </header>

    <slot />

    <footer class="footer f f7">
      Powered by <a href="https://reimannlabs.com/">Reimann Labs</a>
    </footer>
  </div>
  <script is:inline>
    const mobileNav = document.getElementById('mobile-nav');
    const navToggle = document.querySelector('[data-nav-toggle]');

    if (mobileNav instanceof HTMLElement && navToggle instanceof HTMLButtonElement) {
      const mobileLinks = mobileNav.querySelectorAll('a');

      const setOpen = (open) => {
        document.body.dataset.mobileNavOpen = open ? 'true' : 'false';
        navToggle.setAttribute('aria-expanded', String(open));
        navToggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      };

      setOpen(false);

      navToggle.addEventListener('click', () => {
        const isOpen = document.body.dataset.mobileNavOpen === 'true';
        setOpen(!isOpen);
      });

      mobileLinks.forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setOpen(false);
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 720) {
          setOpen(false);
        }
      });
    }
  </script>
</body>
</html>
