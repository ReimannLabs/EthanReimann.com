---
layout: base.njk
---

<article class="container-limited mx-auto">
  <header class="mb-4">
    <h1>{{ title }}</h1>
    <p class="meta">{{ date | date("MMM d, yyyy") }} · {{ readingTime }}</p>

    {% if tags and tags | length > 0 %}
    <p class="mt-2">
      {% for t in tags %}
      <a class="badge custom-tag text-decoration-none me-1" href="/tags/{{ t | slug }}/">{{ t }}</a>
      {% endfor %}
    </p>
    {% endif %}
  </header>

  {% if heroImage %}
  <img src="{{ heroImage }}" class="post-hero rounded mb-4" alt="{{ title }}">
  {% endif %}

  <section>
    {{ content | safe }}
  </section>

  <hr>
  <nav class="d-flex justify-content-between">
    <a href="#" class="btn btn-outline-secondary">← Older</a>
    <a href="/" class="btn btn-outline-primary">Back to home</a>
  </nav>
</article>
