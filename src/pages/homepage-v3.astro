---
/**
 * VARIATION 3: "The Zine"
 * Raw, punk-inflected, DIY zine aesthetic. Intentionally "rough"
 * — mixed type sizes, overlapping elements, rotated photos, heavy
 * borders, stamp-like labels. Feels like a photocopied zine from
 * the 90s but on the web. Still warm and personal.
 */

import AtelierLayout from '../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portraitOutside from '../images/ethan_portrait_outside.jpg';
import performingArts from '../images/ethan_performing_arts.jpg';
import vcfmw from '../images/ethan_VCFMW.jpg';
import portraitInside from '../images/ethan_new_portrait_inside.jpg';
import cameraDarkmirror from '../images/ethan_camera_darkmirror.JPG';

const books = [
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky', active: true },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AtelierLayout>
  <style>
    /* ── Zine wrapper ────────────────────────── */
    .zine {
      position: relative;
    }

    /* ── Utility: stamps & labels ────────────── */
    .stamp {
      display: inline-block;
      border: 3px solid var(--ink);
      padding: 0.3em 0.8em;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      transform: rotate(-3deg);
      position: relative;
    }
    .stamp::after {
      content: '';
      position: absolute;
      inset: 3px;
      border: 1px solid var(--ink);
    }
    .stamp-warm {
      border-color: var(--warm);
      color: var(--warm);
    }
    .stamp-warm::after { border-color: var(--warm); }

    .tag {
      display: inline-block;
      background: var(--ink);
      color: #fafaf8;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.35em 0.7em;
    }
    .tag-warm { background: var(--warm); }

    /* ── Heavy dividers ──────────────────────── */
    .cut-line {
      border: none;
      border-top: 3px solid var(--ink);
      margin: 3rem 0;
      position: relative;
    }
    .cut-line::before {
      content: '✂';
      position: absolute;
      top: -0.7em;
      left: 1rem;
      background: var(--bg);
      padding: 0 0.4em;
      font-size: 0.9rem;
    }
    .thick-rule {
      border: none;
      border-top: 6px solid var(--ink);
      margin: 0;
    }

    /* ── Hero ─────────────────────────────────── */
    .zine-hero {
      padding: 3rem 0 2rem;
      position: relative;
    }
    .zine-hero-pre {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }
    .zine-hero h1 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: clamp(3rem, 8vw, 7rem);
      line-height: 0.88;
      letter-spacing: -0.05em;
      text-transform: uppercase;
    }
    .zine-hero h1 span {
      display: block;
    }
    .zine-hero .line-2 {
      color: var(--warm);
      font-style: italic;
      text-transform: none;
      margin-left: 0.5em;
    }
    .hero-aside {
      position: absolute;
      right: 0;
      top: 3.5rem;
    }
    @media (max-width: 580px) {
      .hero-aside { position: static; margin-top: 1rem; }
    }

    /* ── Collage section ─────────────────────── */
    .collage {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
      align-items: start;
    }
    @media (max-width: 580px) {
      .collage { grid-template-columns: 1fr; }
    }
    .collage-text {
      padding-top: 1rem;
    }
    .collage-text p {
      font-size: 1.05rem;
      line-height: 1.75;
      color: var(--ink);
      margin-bottom: 1em;
    }
    .collage-photos {
      position: relative;
      min-height: 380px;
    }
    .collage-photo {
      position: absolute;
      border: 4px solid #fff;
      box-shadow: 2px 3px 12px rgba(28,25,23,0.12);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), z-index 0s;
    }
    .collage-photo:hover {
      z-index: 10;
      transform: scale(1.08) rotate(0deg) !important;
    }
    .cp-1 {
      width: 65%;
      top: 0;
      left: 5%;
      transform: rotate(-4deg);
      z-index: 2;
    }
    .cp-2 {
      width: 55%;
      top: 30%;
      right: 0;
      transform: rotate(3deg);
      z-index: 3;
    }
    .cp-3 {
      width: 45%;
      bottom: 0;
      left: 15%;
      transform: rotate(-2deg);
      z-index: 1;
    }
    @media (max-width: 580px) {
      .collage-photos {
        min-height: 280px;
      }
      .cp-1 { width: 60%; }
      .cp-2 { width: 50%; }
      .cp-3 { width: 40%; }
    }

    /* ── Directory / nav ─────────────────────── */
    .zine-nav {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border: 3px solid var(--ink);
    }
    @media (max-width: 480px) {
      .zine-nav { grid-template-columns: 1fr; }
    }
    .zine-nav-item {
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      border-right: 3px solid var(--ink);
      border-bottom: 3px solid var(--ink);
      transition: background 0.15s;
      position: relative;
    }
    .zine-nav-item:nth-child(2n) { border-right: none; }
    .zine-nav-item:nth-child(n+3) { border-bottom: none; }
    @media (max-width: 480px) {
      .zine-nav-item { border-right: none; }
      .zine-nav-item:last-child { border-bottom: none; }
      .zine-nav-item:nth-child(n+3) { border-bottom: 3px solid var(--ink); }
    }
    .zine-nav-item:hover {
      background: var(--ink);
      color: #fafaf8;
    }
    .zine-nav-item:hover .nav-num { color: var(--warm); }
    .nav-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 2.2rem;
      line-height: 1;
      color: var(--border);
      transition: color 0.15s;
    }
    .nav-name {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.15rem;
      margin-top: 0.3rem;
      display: block;
    }
    .nav-desc-text {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }
    .zine-nav-item:hover .nav-desc-text { color: rgba(250,250,248,0.5); }

    /* ── Bio strip ───────────────────────────── */
    .bio-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      border: 3px solid var(--ink);
      margin: 3rem 0;
    }
    .bio-cell {
      flex: 1 1 160px;
      padding: 1.2rem;
      border-right: 2px solid var(--ink);
      border-bottom: 2px solid var(--ink);
    }
    .bio-cell:last-child { border-right: none; }
    @media (max-width: 640px) {
      .bio-cell { flex: 1 1 50%; }
      .bio-cell:nth-child(2n) { border-right: none; }
    }
    .bio-cell-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--warm);
      margin-bottom: 0.3rem;
    }
    .bio-cell-value {
      font-size: 0.9rem;
      color: var(--ink);
      font-weight: 500;
    }
    .bio-cell-value a { color: var(--warm); text-decoration: none; }

    /* ── Featured photo ──────────────────────── */
    .featured-photo {
      position: relative;
      margin: 0 -2rem;
      overflow: hidden;
    }
    @media (min-width: 960px) { .featured-photo { margin: 0 -4rem; } }
    .featured-photo img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      display: block;
      filter: grayscale(30%) contrast(1.1);
    }
    .featured-label {
      position: absolute;
      bottom: 1.5rem;
      left: 1.5rem;
    }

    /* ── Blog ─────────────────────────────────── */
    .zine-blog {
      padding: 3rem 0;
    }
    .zine-blog-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .zine-blog-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 2rem;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .blog-entry {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 1rem;
      align-items: baseline;
      padding: 0.8em 0;
      border-bottom: 2px solid var(--ink);
    }
    .blog-entry:first-of-type { border-top: 2px solid var(--ink); }
    .blog-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.4rem;
      color: var(--border);
      min-width: 2em;
    }
    .blog-entry a {
      font-size: 1rem;
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      transition: color 0.15s;
    }
    .blog-entry a:hover { color: var(--warm); }
    .blog-entry time {
      font-size: 0.75rem;
      color: var(--muted);
      white-space: nowrap;
    }

    /* ── Lists: torn-paper style ─────────────── */
    .torn-lists {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding: 3rem 0;
    }
    @media (max-width: 580px) { .torn-lists { grid-template-columns: 1fr; } }
    .torn-card {
      background: #fff;
      border: 2px solid var(--ink);
      padding: 1.5rem;
      position: relative;
      transform: rotate(-0.5deg);
    }
    .torn-card:nth-child(2) { transform: rotate(0.5deg); }
    .torn-card-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding-bottom: 0.6em;
      margin-bottom: 0.8em;
      border-bottom: 3px solid var(--ink);
    }
    .torn-item {
      display: flex;
      justify-content: space-between;
      gap: 0.8em;
      padding: 0.35em 0;
      font-size: 0.85rem;
      border-bottom: 1px dashed var(--border);
    }
    .torn-item:last-child { border-bottom: none; }
    .torn-title { color: var(--ink); }
    .torn-meta { color: var(--muted); font-size: 0.8em; text-align: right; white-space: nowrap; }
    .badge {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
      background: var(--warm);
      padding: 0.2em 0.6em;
      border-radius: 0;
    }

    /* ── Closing manifesto ───────────────────── */
    .manifesto {
      background: var(--ink);
      color: #fafaf8;
      margin: 0 -2rem;
      padding: 3.5rem 2rem;
      text-align: center;
    }
    @media (min-width: 960px) { .manifesto { margin: 0 -4rem; padding: 4rem 3rem; } }
    .manifesto p {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: clamp(1.1rem, 2vw, 1.6rem);
      line-height: 1.6;
      max-width: 550px;
      margin: 0 auto;
      color: rgba(250,250,248,0.8);
    }
    .manifesto .stamp {
      border-color: var(--warm);
      color: var(--warm);
      margin-top: 2rem;
      transform: rotate(-2deg);
    }
    .manifesto .stamp::after { border-color: var(--warm); }
  </style>

  <div class="zine">

    <!-- ═══ HERO ═══ -->
    <section class="zine-hero f f2">
      <p class="zine-hero-pre">Issue No. 1 &mdash; Personal Website</p>
      <h1>
        <span>Ethan</span>
        <span class="line-2">Reimann</span>
      </h1>
      <div class="hero-aside">
        <span class="stamp stamp-warm">Est. 2009</span>
      </div>
    </section>

    <hr class="thick-rule" />

    <!-- ═══ COLLAGE: INTRO + PHOTOS ═══ -->
    <section class="collage f f3">
      <div class="collage-text">
        <span class="tag" style="margin-bottom:1rem;">About</span>
        <p>
          Hello World! I'm Ethan Reimann, a 10th grade student in the
          United States. This is one of my many attempts at a website
          in this modern world where personal websites are very uncommon.
        </p>
        <p>
          You can find me and my work all across the internet —
          everything from YouTube videos to contributions to various
          GitHub projects. This site is the home base for all of it.
        </p>
      </div>
      <div class="collage-photos">
        <Image class="collage-photo cp-1" src={portraitOutside} alt="Ethan outdoors" width={400} quality={82} />
        <Image class="collage-photo cp-2" src={performingArts} alt="Theatre" width={350} quality={80} />
        <Image class="collage-photo cp-3" src={vcfmw} alt="VCFMW" width={300} quality={80} />
      </div>
    </section>

    <!-- ═══ NAV GRID ═══ -->
    <nav class="zine-nav f f4">
      <a class="zine-nav-item" href="/photography/">
        <span class="nav-num">01</span>
        <span class="nav-name">Photography</span>
        <span class="nav-desc-text">Moments through the lens</span>
      </a>
      <a class="zine-nav-item" href="/projects/">
        <span class="nav-num">02</span>
        <span class="nav-name">Projects</span>
        <span class="nav-desc-text">Things I've built</span>
      </a>
      <a class="zine-nav-item" href="/blog/">
        <span class="nav-num">03</span>
        <span class="nav-name">The Blog</span>
        <span class="nav-desc-text">Digital public journal</span>
      </a>
      <a class="zine-nav-item" href="https://github.com/ReimannLabs">
        <span class="nav-num">04</span>
        <span class="nav-name">GitHub</span>
        <span class="nav-desc-text">Open source & code</span>
      </a>
    </nav>

    <!-- ═══ BIO STRIP ═══ -->
    <div class="bio-strip f f4">
      <div class="bio-cell">
        <div class="bio-cell-label">Age</div>
        <div class="bio-cell-value">16</div>
      </div>
      <div class="bio-cell">
        <div class="bio-cell-label">Grade</div>
        <div class="bio-cell-value">10th</div>
      </div>
      <div class="bio-cell">
        <div class="bio-cell-label">Interests</div>
        <div class="bio-cell-value">Econ, Music, Finance</div>
      </div>
      <div class="bio-cell">
        <div class="bio-cell-label">Email</div>
        <div class="bio-cell-value"><a href="mailto:hello@ethanreimann.com">hello@ethanreimann.com</a></div>
      </div>
      <div class="bio-cell">
        <div class="bio-cell-label">Hobbies</div>
        <div class="bio-cell-value">Theatre, Software, 4-H, Writing</div>
      </div>
    </div>

    <!-- ═══ FEATURED PHOTO ═══ -->
    <div class="featured-photo f f5">
      <Image src={cameraDarkmirror} alt="Ethan with camera" width={1200} quality={85} />
      <span class="featured-label"><span class="tag tag-warm">Photo</span></span>
    </div>

    <hr class="cut-line" />

    <!-- ═══ BLOG ═══ -->
    <section class="zine-blog f f5">
      <div class="zine-blog-header">
        <h2 class="zine-blog-title">The Blog</h2>
        <span class="stamp stamp-warm">New Posts</span>
      </div>
      {sortedPosts.map((post, i) => (
        <div class="blog-entry">
          <span class="blog-num">{String(i + 1).padStart(2, '0')}</span>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
      ))}
    </section>

    <!-- ═══ BOOKS & ALBUMS ═══ -->
    <div class="torn-lists f f6">
      <div class="torn-card">
        <h2 class="torn-card-title">Bookshelf</h2>
        {books.map((b) => (
          <div class="torn-item">
            <span class="torn-title">{b.title}</span>
            {b.active ? <span class="badge">Reading</span> : <span class="torn-meta">{b.author}</span>}
          </div>
        ))}
      </div>
      <div class="torn-card">
        <h2 class="torn-card-title">On Rotation</h2>
        {albums.map((a) => (
          <div class="torn-item">
            <span class="torn-title">{a.title}</span>
            <span class="torn-meta">{a.artist}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ═══ MANIFESTO ═══ -->
    <div class="manifesto f f7">
      <p>
        Personal websites have always felt like a lost art. I would rather
        my work be on a website owned by me rather than some billionaire
        social media platform. This site shall grow with time.
      </p>
      <div><span class="stamp">Ethan Reimann</span></div>
    </div>

  </div>
</AtelierLayout>
