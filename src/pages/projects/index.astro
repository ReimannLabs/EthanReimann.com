---
import AtelierLayout from '../../layouts/AtelierLayout.astro';

const sections = [
  {
    id: 'school',
    title: 'School',
    num: '01',
    description: "Projects from my PBL school — research, building, and learning by doing.",
    projects: [
      {
        title: 'Cerro Gordo History',
        description: 'A website and deep-dive research project into the history of Cerro Gordo, a ghost town in the Inyo Mountains of California.',
        tags: ['Research', 'History', 'Web'],
      },
      {
        title: 'Learning PCB Design',
        description: 'Built a small programmable keyboard from scratch — learning schematic capture, PCB layout, and fabrication along the way.',
        tags: ['Hardware', 'Electronics'],
      },
      {
        title: 'Producing an Album',
        description: 'Working with my father David Reimann to produce a simple piano EP by end of April — an experiment in mixing, mastering, and learning the craft.',
        tags: ['Music', 'Production'],
      },
    ],
  },
  {
    id: 'software',
    title: 'Software',
    num: '02',
    description: 'Apps and platforms I\'m building.',
    projects: [
      {
        title: 'FarmKit',
        description: 'A Facebook Marketplace-like platform for connecting local farms with local buyers. Think farm-to-table, but for everything. Sign up now at farmkit.us.',
        tags: ['Platform', 'Agriculture'],
        status: 'Open Beta',
        link: 'https://farmkit.us',
      },
      {
        title: 'Report',
        description: 'A project management dashboard purpose-built for PBL schools — tracking projects, progress, and assessment in one place.',
        tags: ['EdTech', 'Dashboard'],
        status: 'Alpha',
      },
      {
        title: 'Flux',
        description: 'A Discord-like communication app for my friends and I, built on Convex and Railway.',
        tags: ['Communication', 'Real-time'],
        status: 'Early Dev',
      },
    ],
  },
  {
    id: 'business',
    title: 'Business',
    num: '03',
    description: 'Ventures and brands I\'m involved with.',
    projects: [
      {
        title: 'Reimann Labs',
        description: 'My software and website business.',
        tags: ['Software', 'Web'],
        link: 'https://reimannlabs.com',
      },
      {
        title: 'Reimann Hobby Acres',
        description: 'My family\'s hobby farm and soon-to-be equine therapy center.',
        tags: ['Agriculture', 'Equine Therapy'],
      },
      {
        title: 'Badger Web Works',
        description: 'A subscription-based website design service for small businesses.',
        tags: ['Web Design', 'Service'],
        link: 'https://badgerwebworks.com',
      },
    ],
  },
];
---

<AtelierLayout title="Projects | Ethan Reimann" description="Projects by Ethan Reimann" activeNav="projects">
  <style is:global>
    /* ── Projects Page ── */
    .projects-page { padding: 3rem 0; }

    .projects-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }
    .projects-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: clamp(1.8rem, 3vw + 0.5rem, 2.8rem);
      line-height: 1.2;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .projects-stamp {
      display: inline-block;
      border: 2.5px solid var(--warm);
      color: var(--warm);
      padding: 0.25em 0.7em;
      font-size: 0.58rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      position: relative;
      line-height: 1.4;
      transform: rotate(-2.5deg);
    }
    .projects-stamp::after {
      content: '';
      position: absolute;
      inset: 2.5px;
      border: 1px solid var(--warm);
    }
    .projects-subtitle {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--ink);
    }

    /* ── Section ── */
    .proj-section { margin-bottom: 2.5rem; }
    .proj-section:last-child { margin-bottom: 0; }
    .proj-section-header {
      display: flex;
      align-items: baseline;
      gap: 0.8rem;
      margin-bottom: 0.3rem;
    }
    .proj-section-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.8rem;
      color: var(--border);
      line-height: 1;
    }
    .proj-section-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--ink);
    }
    .proj-section-count {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }
    .proj-section-desc {
      color: var(--muted);
      font-size: 0.82rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1.5px dashed var(--border);
    }

    /* ── Card Grid ── */
    .proj-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 0.6rem;
    }
    @media (max-width: 480px) {
      .proj-card-grid { grid-template-columns: 1fr; }
    }

    /* ── Project Card ── */
    .proj-card {
      border: 2px solid var(--ink);
      border-radius: 8px;
      padding: 1.25rem 1.35rem;
      background: var(--surface);
      transition: border-color 0.2s, box-shadow 0.2s;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .proj-card:hover {
      border-color: var(--warm);
      box-shadow: 0 2px 12px rgba(180, 83, 9, 0.08);
    }
    .proj-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .proj-card-name {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.02rem;
      color: var(--ink);
    }
    .proj-status {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.2em 0.6em;
      border-radius: 2px;
      flex-shrink: 0;
      color: #fff;
    }
    .proj-status-alpha { background: var(--warm); }
    .proj-status-beta { background: var(--ink); }
    .proj-status-open-beta { background: #16a34a; }
    .proj-status-early-dev { background: var(--muted); }
    .proj-status-in-progress { background: #2563eb; }
    .proj-card-desc {
      color: var(--muted);
      font-size: 0.85rem;
      line-height: 1.55;
    }
    .proj-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      margin-top: auto;
      padding-top: 0.4rem;
    }
    .proj-tags { display: flex; flex-wrap: wrap; gap: 0.3em; }
    .proj-tag {
      font-size: 0.5rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--warm);
      background: rgba(180, 83, 9, 0.08);
      padding: 0.2em 0.55em;
      border-radius: 2px;
    }
    .proj-link {
      font-size: 0.75rem;
      color: var(--warm);
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .proj-link:hover { text-decoration: underline; }
  </style>

  <section class="projects-page f f2">
    <div class="projects-header">
      <h1 class="projects-title">Projects</h1>
      <span class="projects-stamp">Building Things</span>
    </div>
    <p class="projects-subtitle">Things I've built, am building, and am involved with.</p>

    {sections.map((section, si) => (
      <div class={`proj-section f f${si + 3}`}>
        <div class="proj-section-header">
          <span class="proj-section-num">{section.num}</span>
          <h2 class="proj-section-title">{section.title}</h2>
          <span class="proj-section-count">{section.projects.length} project{section.projects.length !== 1 ? 's' : ''}</span>
        </div>
        <p class="proj-section-desc">{section.description}</p>

        <div class="proj-card-grid">
          {section.projects.map((project) => (
            <div class="proj-card">
              <div class="proj-card-top">
                <h3 class="proj-card-name">{project.title}</h3>
                {project.status && (
                  <span class={`proj-status proj-status-${project.status.toLowerCase().replace(/\s+/g, '-')}`}>{project.status}</span>
                )}
              </div>
              <p class="proj-card-desc">{project.description}</p>
              <div class="proj-card-footer">
                <div class="proj-tags">
                  {project.tags.map((tag) => (
                    <span class="proj-tag">{tag}</span>
                  ))}
                </div>
                {project.link && (
                  <a class="proj-link" href={project.link} target="_blank" rel="noopener noreferrer">
                    {project.link.replace(/^https?:\/\//, '')} ›
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>
</AtelierLayout>
