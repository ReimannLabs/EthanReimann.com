---
/**
 * VARIATION 2: "The Scroll"
 * Full-viewport, cinematic sections. Each content block takes up
 * close to the full screen height. Enormous typography, photos that
 * bleed edge-to-edge, heavy use of negative space. Inspired by
 * fashion lookbooks and art portfolio sites.
 */

import AtelierLayout from '../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portraitOutside from '../images/ethan_portrait_outside.jpg';
import performingArts from '../images/ethan_performing_arts.jpg';
import vcfmw from '../images/ethan_VCFMW.jpg';
import portraitInside from '../images/ethan_new_portrait_inside.jpg';
import cameraDarkmirror from '../images/ethan_camera_darkmirror.JPG';

const books = [
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky', active: true },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AtelierLayout>
  <style>
    /* ── Break out of parent container ──────── */
    .scroll-wrapper {
      margin: 0 -2rem;
    }
    @media (min-width: 960px) {
      .scroll-wrapper { margin: 0 -2rem; }
    }

    /* ── Section base ──────────────────────── */
    .scene {
      min-height: 85vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 2rem;
      position: relative;
    }
    .scene-short {
      min-height: auto;
      padding: 5rem 2rem;
    }
    .scene-inner {
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
    }

    /* ── Scene 1: Hero ─────────────────────── */
    .hero-scene {
      min-height: 90vh;
      display: flex;
      align-items: flex-end;
      padding-bottom: 6rem;
    }
    .hero-name {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(3.5rem, 10vw, 9rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
      color: var(--ink);
    }
    .hero-name em {
      font-style: italic;
      color: var(--warm);
      display: block;
    }
    .hero-tag {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 1.5rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── Scene 2: Photo + intro split ────────── */
    .split-scene {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
    @media (max-width: 700px) {
      .split-scene { grid-template-columns: 1fr; min-height: auto; }
    }
    .split-photo {
      position: relative;
      overflow: hidden;
      min-height: 400px;
    }
    .split-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .split-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3rem;
    }
    @media (max-width: 700px) {
      .split-text { padding: 3rem 2rem; }
    }
    .split-text p {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--ink);
      margin-bottom: 1.2em;
    }
    .split-text p:last-of-type { margin-bottom: 0; }
    .split-bio {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
    .bio-line {
      display: flex;
      gap: 1rem;
      padding: 0.35em 0;
      font-size: 0.85rem;
    }
    .bio-key {
      color: var(--warm);
      font-weight: 600;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      min-width: 70px;
      flex-shrink: 0;
      padding-top: 0.15em;
    }
    .bio-val { color: var(--ink); }
    .bio-val a { color: var(--warm); text-decoration: none; }
    .bio-val a:hover { text-decoration: underline; }

    /* ── Scene 3: Navigation marquee ──────── */
    .nav-scene {
      background: var(--ink);
      min-height: auto;
      padding: 0;
    }
    .nav-link {
      display: block;
      text-decoration: none;
      padding: 2rem 2.5rem;
      border-bottom: 1px solid rgba(250,250,248,0.08);
      transition: background 0.25s, padding-left 0.3s;
    }
    .nav-link:last-child { border-bottom: none; }
    .nav-link:hover {
      background: rgba(180, 83, 9, 0.15);
      padding-left: 3.5rem;
    }
    .nav-link-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .nav-link-name {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(1.8rem, 4vw, 3.2rem);
      color: #fafaf8;
      letter-spacing: -0.02em;
    }
    .nav-link-desc {
      color: rgba(250,250,248,0.35);
      font-size: 0.82rem;
    }
    @media (max-width: 580px) {
      .nav-link-desc { display: none; }
    }
    .nav-link-arrow {
      font-size: 1.6rem;
      color: rgba(250,250,248,0.2);
      transition: color 0.2s, transform 0.2s;
      margin-left: 1rem;
    }
    .nav-link:hover .nav-link-arrow {
      color: var(--warm);
      transform: translateX(6px);
    }

    /* ── Scene 4: Photo grid ─────────────── */
    .photo-scene {
      padding: 1rem;
      min-height: auto;
    }
    .photo-row {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 0.5rem;
      max-width: 100%;
    }
    @media (max-width: 580px) {
      .photo-row { grid-template-columns: 1fr 1fr; }
      .photo-row .photo-cell:first-child { grid-column: 1 / -1; }
    }
    .photo-cell {
      overflow: hidden;
      border-radius: 8px;
      position: relative;
    }
    .photo-cell img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 3/2;
      display: block;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .photo-cell:hover img {
      transform: scale(1.06);
    }

    /* ── Scene 5: Blog ───────────────────── */
    .blog-heading {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(2rem, 4vw, 4rem);
      letter-spacing: -0.03em;
      margin-bottom: 0.2em;
    }
    .blog-sub {
      color: var(--muted);
      font-size: 0.88rem;
      font-style: italic;
      margin-bottom: 3rem;
    }
    .blog-entry {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 1.2em 0;
      border-bottom: 1px solid var(--border);
    }
    .blog-entry:first-of-type { border-top: 1px solid var(--border); }
    .blog-entry a {
      font-family: 'Fraunces', serif;
      font-size: 1.2rem;
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }
    .blog-entry a:hover { color: var(--warm); }
    .blog-entry time {
      color: var(--muted);
      font-size: 0.78rem;
      white-space: nowrap;
    }

    /* ── Scene 6: Lists side-by-side ─────── */
    .lists-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    @media (max-width: 640px) { .lists-grid { grid-template-columns: 1fr; gap: 3rem; } }
    .list-heading {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: 1.8rem;
      letter-spacing: -0.02em;
      margin-bottom: 1.2rem;
      padding-bottom: 0.8rem;
      border-bottom: 2px solid var(--ink);
    }
    .list-row {
      display: flex;
      justify-content: space-between;
      gap: 1em;
      padding: 0.5em 0;
      font-size: 0.9rem;
      border-bottom: 1px solid var(--border);
    }
    .list-row:last-child { border-bottom: none; }
    .list-title { color: var(--ink); }
    .list-meta { color: var(--muted); font-size: 0.82em; text-align: right; white-space: nowrap; }
    .badge {
      font-size: 0.58rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--warm);
      background: var(--warm-light);
      padding: 0.2em 0.65em;
      border-radius: 3px;
    }

    /* ── Scene 7: Closing manifesto ──────── */
    .manifesto-scene {
      background: var(--ink);
      color: #fafaf8;
      text-align: center;
      min-height: 60vh;
    }
    .manifesto-text {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: clamp(1.2rem, 2.5vw, 2rem);
      line-height: 1.55;
      max-width: 600px;
      margin: 0 auto;
      color: rgba(250,250,248,0.85);
    }
    .manifesto-rule {
      width: 40px;
      height: 2px;
      background: var(--warm);
      border: none;
      margin: 2rem auto;
    }
    .manifesto-sig {
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(250,250,248,0.35);
    }
  </style>

  <div class="scroll-wrapper">

    <!-- SCENE 1: HERO -->
    <section class="hero-scene scene f f2">
      <div class="scene-inner">
        <h1 class="hero-name">
          Ethan
          <em>Reimann</em>
        </h1>
        <p class="hero-tag">Student &middot; Builder &middot; Musician &middot; Writer</p>
      </div>
    </section>

    <!-- SCENE 2: PHOTO + INTRO SPLIT -->
    <section class="split-scene f f3">
      <div class="split-photo">
        <Image src={portraitOutside} alt="Ethan Reimann outdoors" width={900} quality={88} />
      </div>
      <div class="split-text">
        <p>
          Hello World! I'm a 10th grade student in the United
          States. This is one of my many attempts at a website in
          this modern world where personal websites are very uncommon.
        </p>
        <p>
          You can find me and my work all across the internet —
          everything from YouTube videos to contributions to
          various GitHub projects. This site is the home base
          for all of it.
        </p>
        <div class="split-bio">
          <div class="bio-line"><span class="bio-key">Age</span><span class="bio-val">16 — born July 2009</span></div>
          <div class="bio-line"><span class="bio-key">Study</span><span class="bio-val">10th Grade</span></div>
          <div class="bio-line"><span class="bio-key">Hobbies</span><span class="bio-val">Theatre, Music, Software, 4-H</span></div>
          <div class="bio-line"><span class="bio-key">Email</span><span class="bio-val"><a href="mailto:hello@ethanreimann.com">hello@ethanreimann.com</a></span></div>
        </div>
      </div>
    </section>

    <!-- SCENE 3: NAVIGATION -->
    <nav class="nav-scene">
      <a class="nav-link" href="/photography/">
        <div class="nav-link-inner">
          <span class="nav-link-name">Photography</span>
          <span class="nav-link-desc">Moments captured through the lens</span>
          <span class="nav-link-arrow">&rarr;</span>
        </div>
      </a>
      <a class="nav-link" href="/projects/">
        <div class="nav-link-inner">
          <span class="nav-link-name">Projects</span>
          <span class="nav-link-desc">Things I've built and contributed to</span>
          <span class="nav-link-arrow">&rarr;</span>
        </div>
      </a>
      <a class="nav-link" href="/blog/">
        <div class="nav-link-inner">
          <span class="nav-link-name">The Blog</span>
          <span class="nav-link-desc">A digital public journal</span>
          <span class="nav-link-arrow">&rarr;</span>
        </div>
      </a>
      <a class="nav-link" href="https://github.com/ReimannLabs">
        <div class="nav-link-inner">
          <span class="nav-link-name">GitHub</span>
          <span class="nav-link-desc">Open source work and code</span>
          <span class="nav-link-arrow">&rarr;</span>
        </div>
      </a>
    </nav>

    <!-- SCENE 4: PHOTO GRID -->
    <section class="photo-scene">
      <div class="photo-row">
        <div class="photo-cell">
          <Image src={performingArts} alt="Theatre" width={800} quality={82} />
        </div>
        <div class="photo-cell">
          <Image src={vcfmw} alt="VCFMW" width={500} quality={82} />
        </div>
        <div class="photo-cell">
          <Image src={portraitInside} alt="Portrait" width={500} quality={82} />
        </div>
      </div>
    </section>

    <!-- SCENE 5: BLOG -->
    <section class="scene scene-short">
      <div class="scene-inner">
        <h2 class="blog-heading">The Blog</h2>
        <p class="blog-sub">No set purpose — a digital public journal.</p>
        {sortedPosts.map((post) => (
          <div class="blog-entry">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        ))}
      </div>
    </section>

    <!-- SCENE 6: BOOKS & ALBUMS -->
    <section class="scene scene-short">
      <div class="scene-inner">
        <div class="lists-grid">
          <div>
            <h2 class="list-heading">Bookshelf</h2>
            {books.map((b) => (
              <div class="list-row">
                <span class="list-title">{b.title}</span>
                {b.active ? <span class="badge">Reading</span> : <span class="list-meta">{b.author}</span>}
              </div>
            ))}
          </div>
          <div>
            <h2 class="list-heading">On Rotation</h2>
            {albums.map((a) => (
              <div class="list-row">
                <span class="list-title">{a.title}</span>
                <span class="list-meta">{a.artist}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SCENE 7: MANIFESTO -->
    <section class="scene manifesto-scene">
      <div class="scene-inner">
        <p class="manifesto-text">
          Personal websites have always felt like a lost art.
          I would rather my work be on a website owned by me
          rather than some billionaire social media platform.
          This site shall grow with time.
        </p>
        <hr class="manifesto-rule" />
        <p class="manifesto-sig">Ethan Reimann</p>
      </div>
    </section>

  </div>
</AtelierLayout>
