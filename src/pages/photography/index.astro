---
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';

/* ── Glob each folder's images ── */
function loadFolder(glob: Record<string, { default: ImageMetadata }>, altPrefix: string) {
  return Object.entries(glob)
    .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
    .map(([path, mod]) => {
      const name = path.split('/').pop()?.replace(/\.\w+$/, '') ?? 'Photo';
      return { src: mod.default, alt: `${altPrefix} photo`, name };
    });
}

const usWestTrip = loadFolder(
  import.meta.glob<{ default: ImageMetadata }>('../../images/us-west-trip/*.{JPEG,JPG,jpeg,jpg,png,webp}', { eager: true }),
  'US West Trip'
);

const theatre = loadFolder(
  import.meta.glob<{ default: ImageMetadata }>('../../images/theatre/*.{JPEG,JPG,jpeg,jpg,png,webp}', { eager: true }),
  'Theatre'
);

const chickens = loadFolder(
  import.meta.glob<{ default: ImageMetadata }>('../../images/chickens/*.{JPEG,JPG,jpeg,jpg,png,webp}', { eager: true }),
  'Chicken'
);

const other = loadFolder(
  import.meta.glob<{ default: ImageMetadata }>('../../images/other/*.{JPEG,JPG,jpeg,jpg,png,webp}', { eager: true }),
  'Other'
);

const folders = [
  {
    id: 'us-west-trip',
    name: '2025 US West Trip',
    photos: usWestTrip.map((p) => ({ src: p.src, alt: p.alt, name: p.name + '.jpg', fullSrc: p.src.src })),
  },
  {
    id: 'theatre',
    name: 'Theatre',
    photos: theatre.map((p) => ({ src: p.src, alt: p.alt, name: p.name + '.jpg', fullSrc: p.src.src })),
  },
  {
    id: 'chickens',
    name: 'Chickens',
    photos: chickens.map((p) => ({ src: p.src, alt: p.alt, name: p.name + '.jpg', fullSrc: p.src.src })),
  },
  {
    id: 'other',
    name: 'Other',
    photos: other.map((p) => ({ src: p.src, alt: p.alt, name: p.name + '.jpg', fullSrc: p.src.src })),
  },
].map((f) => ({ ...f, count: f.photos.length }));

const totalPhotos = folders.reduce((a, f) => a + f.count, 0);
---

<AtelierLayout title="Photography | Ethan Reimann" description="Photos by Ethan Reimann" activeNav="photography">
  <style is:global>
    /* ── Photography Page ── */
    .photo-page { padding: 3rem 0; }

    .photo-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }
    .photo-page-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: clamp(1.8rem, 3vw + 0.5rem, 2.8rem);
      line-height: 1.2;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .photo-stamp {
      display: inline-block;
      border: 2.5px solid var(--warm);
      color: var(--warm);
      padding: 0.25em 0.7em;
      font-size: 0.58rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      position: relative;
      line-height: 1.4;
      transform: rotate(-2.5deg);
    }
    .photo-stamp::after {
      content: '';
      position: absolute;
      inset: 2.5px;
      border: 1px solid var(--warm);
    }
    .photo-subtitle {
      color: var(--muted);
      font-size: 0.88rem;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--ink);
    }

    /* ── Breadcrumb ── */
    .photo-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.82rem;
      margin-bottom: 1.5rem;
    }
    .photo-breadcrumb-btn {
      background: none;
      border: 2px solid var(--border);
      border-radius: 6px;
      font-family: 'Karla', sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--warm);
      cursor: pointer;
      padding: 0.25em 0.6em;
      transition: border-color 0.15s;
    }
    .photo-breadcrumb-btn:hover { border-color: var(--ink); }
    .photo-breadcrumb-sep { color: var(--border); }
    .photo-breadcrumb-current { font-weight: 700; color: var(--ink); }

    /* ── Album grid (root) ── */
    .album-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.6rem;
    }
    .album-card {
      border: 2px solid var(--ink);
      border-radius: 8px;
      padding: 1.4rem;
      background: var(--surface);
      cursor: pointer;
      transition: border-color 0.2s, box-shadow 0.2s;
      text-align: left;
      font-family: 'Karla', sans-serif;
      font-size: inherit;
      width: 100%;
      color: var(--ink);
    }
    .album-card:hover {
      border-color: var(--warm);
      box-shadow: 0 2px 12px rgba(180, 83, 9, 0.08);
    }
    .album-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.8rem;
      color: var(--border);
      line-height: 1;
      display: block;
    }
    .album-card:hover .album-num { color: var(--warm); }
    .album-name {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.02rem;
      margin-top: 0.3rem;
      display: block;
    }
    .album-count {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.2rem;
      display: block;
    }

    /* ── Photo grid (inside album) — CSS columns masonry ── */
    .pg-grid {
      column-count: 4;
      column-gap: 0.6rem;
    }
    @media (max-width: 768px) {
      .pg-grid { column-count: 3; }
    }
    @media (max-width: 480px) {
      .pg-grid { column-count: 2; }
    }
    .pg-item {
      cursor: pointer;
      border: 2px solid var(--ink);
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.2s, box-shadow 0.2s;
      break-inside: avoid;
      margin-bottom: 0.6rem;
      display: inline-block;
      width: 100%;
      position: relative;
    }
    .pg-item:hover {
      border-color: var(--warm);
      box-shadow: 0 2px 12px rgba(180, 83, 9, 0.08);
    }
    .pg-thumb {
      width: 100%;
      height: auto;
      display: block;
    }
    .pg-name-wrap {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.8rem 0.55rem 0.45rem;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        var(--pg-fade, rgba(0,0,0,0.55)) 100%
      );
      pointer-events: none;
    }
    .pg-name {
      font-size: 0.65rem;
      font-weight: 600;
      color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.5);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* ── Lightbox ── */
    .lb-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0,0,0,0.88);
      align-items: center;
      justify-content: center;
      padding: 2rem;
      cursor: zoom-out;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .lb-overlay.open { display: flex; }
    .lb-img {
      max-width: 90vw;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 6px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.4);
      animation: lbIn 0.25s ease-out;
    }
    @keyframes lbIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    .lb-close {
      position: absolute;
      top: 1.25rem;
      right: 1.5rem;
      background: none;
      border: none;
      color: white;
      font-size: 1.8rem;
      cursor: pointer;
      opacity: 0.7;
      transition: opacity 0.15s;
      line-height: 1;
    }
    .lb-close:hover { opacity: 1; }
    .lb-caption {
      position: absolute;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,0.7);
      font-size: 0.78rem;
      text-align: center;
      max-width: 80%;
    }
    .lb-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(255,255,255,0.1);
      border: none;
      color: white;
      font-size: 1.5rem;
      padding: 0.6rem 0.8rem;
      cursor: pointer;
      border-radius: 8px;
      opacity: 0.6;
      transition: opacity 0.15s, background 0.15s;
    }
    .lb-nav:hover { opacity: 1; background: rgba(255,255,255,0.2); }
    .lb-prev { left: 1rem; }
    .lb-next { right: 1rem; }

    .pg-empty {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--muted);
      font-style: italic;
    }
    .pg-hidden { display: none !important; }

    /* ── Copyright disclaimer ── */
    .photo-copyright {
      margin-top: 2.5rem;
      padding: 1rem 1.25rem;
      border: 1.5px dashed var(--border);
      border-radius: 8px;
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.6;
      text-align: center;
    }
    .photo-copyright strong {
      color: var(--ink);
      font-weight: 700;
    }
    .photo-copyright a {
      color: var(--warm);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .photo-copyright a:hover { text-decoration: none; }
  </style>

  <section class="photo-page f f2">
    <div class="photo-header">
      <h1 class="photo-page-title">Photography</h1>
      <span class="photo-stamp">{totalPhotos} Photos</span>
    </div>
    <p class="photo-subtitle">Moments captured through the lens, organized by album.</p>

    <div class="photo-breadcrumb" id="breadcrumb">
      <span class="photo-breadcrumb-current">All Albums</span>
    </div>

    <!-- Root: Album cards -->
    <div class="album-grid" id="rootView">
      {folders.map((folder, i) => (
        <button class="album-card" data-open={folder.id}>
          <span class="album-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="album-name">{folder.name}</span>
          <span class="album-count">{folder.count > 0 ? `${folder.count} photos` : 'Empty'}</span>
        </button>
      ))}
    </div>

    <!-- Per-album photo grids -->
    {folders.map((folder) => (
      <div class="pg-grid pg-hidden" id={`grid-${folder.id}`} data-folder-grid={folder.id}>
        {folder.photos.map((photo, i) => (
          <div class="pg-item" data-lightbox={folder.id} data-index={i} data-full={photo.fullSrc}>
            <Image class="pg-thumb" src={photo.src} alt={photo.alt} width={400} quality={80} />
            <div class="pg-name-wrap">
              <div class="pg-name">{photo.name}</div>
            </div>
          </div>
        ))}
      </div>
    ))}

    <div class="pg-empty pg-hidden" id="emptyState">No photos in this album yet.</div>

    <div class="photo-copyright">
      <strong>&copy; Ethan Reimann.</strong> All photographs on this page are my original work and protected by copyright.
      Please <a href="mailto:ethan@reimannlabs.com">contact me</a> before using, reproducing, or distributing any of these images.
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lb-overlay" id="lightbox">
    <button class="lb-close" id="lbClose" aria-label="Close">&times;</button>
    <button class="lb-nav lb-prev" id="lbPrev" aria-label="Previous">&#8249;</button>
    <button class="lb-nav lb-next" id="lbNext" aria-label="Next">&#8250;</button>
    <img class="lb-img" id="lbImg" src="" alt="" />
    <div class="lb-caption" id="lbCaption"></div>
  </div>

  <script>
    const rootView = document.getElementById('rootView')!;
    const breadcrumb = document.getElementById('breadcrumb')!;
    const folderGrids = document.querySelectorAll<HTMLElement>('[data-folder-grid]');
    const emptyState = document.getElementById('emptyState')!;

    function navigateTo(folderId: string) {
      rootView.style.display = folderId === 'root' ? 'grid' : 'none';
      emptyState.classList.add('pg-hidden');

      let activeGridHasItems = false;
      folderGrids.forEach((g) => {
        const isActive = g.dataset.folderGrid === folderId;
        g.classList.toggle('pg-hidden', !isActive);
        if (isActive) activeGridHasItems = g.children.length > 0;
      });

      if (folderId !== 'root' && !activeGridHasItems) {
        emptyState.classList.remove('pg-hidden');
        folderGrids.forEach((g) => {
          if (g.dataset.folderGrid === folderId) g.classList.add('pg-hidden');
        });
      }

      if (folderId === 'root') {
        breadcrumb.innerHTML = '<span class="photo-breadcrumb-current">All Albums</span>';
      } else {
        const folderName = document.querySelector(`[data-open="${folderId}"] .album-name`)?.textContent || folderId;
        breadcrumb.innerHTML =
          `<button class="photo-breadcrumb-btn" data-nav="root">&larr; Albums</button>` +
          `<span class="photo-breadcrumb-sep">/</span>` +
          `<span class="photo-breadcrumb-current">${folderName}</span>`;
        breadcrumb.querySelector('[data-nav="root"]')?.addEventListener('click', () => navigateTo('root'));
      }
    }

    document.querySelectorAll<HTMLButtonElement>('.album-card').forEach((btn) => {
      btn.addEventListener('click', () => navigateTo(btn.dataset.open || 'root'));
    });

    // ── Lightbox ──
    const lightbox = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lbImg') as HTMLImageElement;
    const lbCaption = document.getElementById('lbCaption')!;

    let lbPhotos: { src: string; alt: string; name: string }[] = [];
    let lbIndex = 0;

    function openLightbox(folderId: string, index: number) {
      const grid = document.getElementById(`grid-${folderId}`);
      if (!grid) return;
      lbPhotos = Array.from(grid.querySelectorAll<HTMLElement>('.pg-item')).map((item) => {
        const img = item.querySelector('img')!;
        return {
          src: item.dataset.full || img.src,
          alt: img.alt,
          name: item.querySelector('.pg-name')?.textContent || '',
        };
      });
      lbIndex = index;
      showPhoto();
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function showPhoto() {
      const p = lbPhotos[lbIndex];
      if (!p) return;
      lbImg.src = p.src;
      lbImg.alt = p.alt;
      lbCaption.textContent = `${p.name}  (${lbIndex + 1} of ${lbPhotos.length})`;
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.getElementById('lbClose')!.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.getElementById('lbPrev')!.addEventListener('click', (e) => {
      e.stopPropagation();
      lbIndex = (lbIndex - 1 + lbPhotos.length) % lbPhotos.length;
      showPhoto();
    });
    document.getElementById('lbNext')!.addEventListener('click', (e) => {
      e.stopPropagation();
      lbIndex = (lbIndex + 1) % lbPhotos.length;
      showPhoto();
    });
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') { lbIndex = (lbIndex - 1 + lbPhotos.length) % lbPhotos.length; showPhoto(); }
      if (e.key === 'ArrowRight') { lbIndex = (lbIndex + 1) % lbPhotos.length; showPhoto(); }
    });

    document.querySelectorAll('.pg-item').forEach((item) => {
      item.addEventListener('click', () => {
        const el = item as HTMLElement;
        openLightbox(el.dataset.lightbox!, parseInt(el.dataset.index || '0', 10));
      });
    });

    // ── Color sampling for gradient overlays ──
    function sampleBottomColor(img: HTMLImageElement): string {
      const canvas = document.createElement('canvas');
      const size = 32; // small sample is enough
      canvas.width = size;
      canvas.height = size;
      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      if (!ctx) return 'rgba(0,0,0,0.6)';

      // Draw only the bottom ~25% of the image into our tiny canvas
      const srcY = img.naturalHeight * 0.75;
      const srcH = img.naturalHeight * 0.25;
      ctx.drawImage(img, 0, srcY, img.naturalWidth, srcH, 0, 0, size, size);

      const data = ctx.getImageData(0, 0, size, size).data;
      let r = 0, g = 0, b = 0, count = 0;
      for (let i = 0; i < data.length; i += 4) {
        r += data[i];
        g += data[i + 1];
        b += data[i + 2];
        count++;
      }
      r = Math.round(r / count);
      g = Math.round(g / count);
      b = Math.round(b / count);
      return `rgba(${r},${g},${b},0.85)`;
    }

    document.querySelectorAll<HTMLElement>('.pg-item').forEach((item) => {
      const img = item.querySelector<HTMLImageElement>('.pg-thumb');
      if (!img) return;

      function applyColor() {
        if (img!.naturalWidth === 0) return; // not decoded yet
        try {
          const color = sampleBottomColor(img!);
          item.style.setProperty('--pg-fade', color);
        } catch (_) {
          // CORS or other canvas error — keep default dark fallback
        }
      }

      if (img.complete && img.naturalWidth > 0) {
        applyColor();
      } else {
        img.addEventListener('load', applyColor);
      }
    });
  </script>
</AtelierLayout>
