---
/**
 * V4: HOMESTEAD — Warm, inviting, cabin-on-the-internet
 * Earthy palette, generous spacing, handcrafted touches.
 * The "welcome to my home" of websites — distinct rooms/areas.
 * Natural textures, rounded edges, soft shadows, a place to linger.
 */
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Ethan Reimann — Homestead</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,600;0,6..12,700;1,6..12,400&family=Caveat:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f0e8;
      --surface: #fffcf5;
      --ink: #3b3127;
      --muted: #8a7e6d;
      --border: #ddd5c7;
      --green: #4a7c59;
      --green-light: rgba(74, 124, 89, 0.08);
      --amber: #b8860b;
      --shadow: 0 2px 12px rgba(59, 49, 39, 0.06);
      --shadow-hover: 0 4px 20px rgba(59, 49, 39, 0.1);
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Nunito Sans', sans-serif;
      font-size: clamp(0.9rem, 0.8rem + 0.4vw, 1.05rem);
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      /* Subtle warmth gradient */
      background-image:
        radial-gradient(ellipse at 30% 0%, rgba(184, 134, 11, 0.04) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 100%, rgba(74, 124, 89, 0.03) 0%, transparent 50%);
      background-attachment: fixed;
    }

    ::selection { background: var(--green); color: white; }

    .page { max-width: 780px; margin: 0 auto; padding: 0 1.5rem; }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2rem 0;
    }
    .logo {
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 1.05rem;
    }
    .logo a { color: var(--ink); text-decoration: none; }
    .header-nav { display: flex; gap: 1.5rem; list-style: none; }
    .header-nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.2s;
    }
    .header-nav a:hover { color: var(--green); }

    /* Welcome hero */
    .welcome {
      background: var(--surface);
      border-radius: 16px;
      padding: 3rem;
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
    }
    .welcome-eyebrow {
      font-family: 'Caveat', cursive;
      font-size: 1.2rem;
      color: var(--green);
      margin-bottom: 0.3em;
    }
    .welcome h1 {
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: clamp(1.8rem, 3vw + 0.5rem, 2.8rem);
      line-height: 1.2;
      letter-spacing: -0.01em;
      margin-bottom: 0.5em;
    }
    .welcome p { color: var(--muted); max-width: 540px; }

    /* About panel */
    .about-panel {
      background: var(--surface);
      border-radius: 16px;
      padding: 2.5rem;
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
      display: grid;
      grid-template-columns: 1fr 180px;
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 600px) {
      .about-panel { grid-template-columns: 1fr; }
      .portrait { max-width: 180px; }
    }
    .about-panel p { margin-bottom: 1em; }
    .portrait {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      border-radius: 12px;
      filter: saturate(0.85);
    }

    /* Room cards */
    .rooms {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 520px) { .rooms { grid-template-columns: 1fr; } }
    .room-card {
      background: var(--surface);
      border-radius: 12px;
      padding: 1.8rem;
      box-shadow: var(--shadow);
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.3em;
      transition: box-shadow 0.25s, transform 0.25s;
    }
    .room-card:hover {
      box-shadow: var(--shadow-hover);
      transform: translateY(-2px);
    }
    .room-icon {
      width: 36px;
      height: 36px;
      background: var(--green-light);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      margin-bottom: 0.5em;
    }
    .room-name {
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 1rem;
    }
    .room-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

    /* Callout */
    .warmth-callout {
      background: var(--green-light);
      border-radius: 12px;
      padding: 2rem 2.5rem;
      margin-bottom: 1.5rem;
      border: 1px solid rgba(74, 124, 89, 0.15);
    }
    .warmth-callout strong {
      font-family: 'Lora', serif;
      display: block;
      margin-bottom: 0.3em;
      color: var(--green);
    }
    .warmth-callout p { color: var(--muted); font-size: 0.92rem; }

    /* Content panels */
    .panel {
      background: var(--surface);
      border-radius: 16px;
      padding: 2rem 2.5rem;
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
    }
    .panel h2 {
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 0.8em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }

    /* Two-column panel */
    .panel-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    @media (max-width: 600px) { .panel-cols { grid-template-columns: 1fr; gap: 2rem; } }

    /* Lists */
    .soft-list { list-style: none; }
    .soft-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.4em 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
      gap: 0.8em;
    }
    .soft-list li:last-child { border-bottom: none; }
    .sl-title { font-weight: 600; }
    .sl-meta { color: var(--muted); font-size: 0.82em; white-space: nowrap; }
    .sl-badge {
      font-family: 'Caveat', cursive;
      font-size: 0.85rem;
      color: var(--green);
      font-weight: 700;
    }

    /* Blog */
    .blog-note {
      color: var(--muted);
      font-style: italic;
      font-size: 0.88rem;
      margin-bottom: 0.8em;
    }
    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5em 0;
    }
    .blog-item a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s;
    }
    .blog-item a:hover { color: var(--green); }
    .blog-item time { color: var(--muted); font-size: 0.82rem; }

    /* GitHub button */
    .cta-row { text-align: center; margin: 0.5em 0 1em; }
    .earth-btn {
      display: inline-block;
      font-weight: 700;
      font-size: 0.85rem;
      color: white;
      background: var(--green);
      padding: 0.7em 2em;
      border-radius: 8px;
      text-decoration: none;
      box-shadow: 0 2px 8px rgba(74, 124, 89, 0.2);
      transition: all 0.2s;
    }
    .earth-btn:hover {
      background: #3d6a4b;
      box-shadow: 0 4px 14px rgba(74, 124, 89, 0.3);
      transform: translateY(-1px);
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 2rem 0;
      color: var(--muted);
      font-size: 0.8rem;
    }
    .footer a { color: var(--green); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    .back { position: fixed; top: 1.2em; right: 2em; z-index: 1000; font-size: 0.8rem; }
    .back a { color: var(--muted); text-decoration: none; }
    .back a:hover { color: var(--green); }

    @keyframes rise {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .r { animation: rise 0.65s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .r1 { animation-delay: 0.05s; } .r2 { animation-delay: 0.12s; }
    .r3 { animation-delay: 0.2s; } .r4 { animation-delay: 0.28s; }
    .r5 { animation-delay: 0.36s; } .r6 { animation-delay: 0.44s; }
    .r7 { animation-delay: 0.52s; }
  </style>
</head>
<body>
  <div class="back"><a href="/">&larr; versions</a></div>
  <div class="page">
    <header class="header r r1">
      <div class="logo"><a href="/v4/">Ethan Reimann</a></div>
      <nav><ul class="header-nav">
        <li><a href="/photography/">Photography</a></li>
        <li><a href="/projects/">Projects</a></li>
      </ul></nav>
    </header>

    <div class="welcome r r2">
      <p class="welcome-eyebrow">Welcome home</p>
      <h1>I'm Ethan Reimann, and this is my corner of the internet.</h1>
      <p>A place for my photography, projects, writing, and everything in between.</p>
    </div>

    <div class="about-panel r r3">
      <div>
        <p>
          Hello World! This is one of my many attempts at a website in this
          modern world where personal websites are very uncommon. I'm a 10th
          grade student in the United States.
        </p>
        <p>
          You can find me and my work all across the internet — everything from
          YouTube videos to contributions to various GitHub projects.
        </p>
        <div class="cta-row">
          <a class="earth-btn" href="https://github.com/ReimannLabs">Visit GitHub</a>
        </div>
      </div>
      <img class="portrait" src="/portrait.jpg" alt="Ethan Reimann" width="180" height="240" />
    </div>

    <div class="rooms r r4">
      <a class="room-card" href="/photography/">
        <div class="room-icon">&#128247;</div>
        <span class="room-name">Photography</span>
        <span class="room-desc">Moments captured through the lens</span>
      </a>
      <a class="room-card" href="/projects/">
        <div class="room-icon">&#128736;</div>
        <span class="room-name">Projects</span>
        <span class="room-desc">Things I've built and contributed to</span>
      </a>
      <a class="room-card" href="#blog">
        <div class="room-icon">&#128214;</div>
        <span class="room-name">The Blog</span>
        <span class="room-desc">A digital public journal</span>
      </a>
      <a class="room-card" href="https://github.com/ReimannLabs">
        <div class="room-icon">&#128187;</div>
        <span class="room-name">GitHub</span>
        <span class="room-desc">Open source code and contributions</span>
      </a>
    </div>

    <div class="warmth-callout r r5">
      <strong>Why a personal website?</strong>
      <p>
        Personal websites have always felt like a lost art. I'd rather my work
        live on a site owned by me than on some billionaire's social media platform.
        This site will grow with time.
      </p>
    </div>

    <div class="panel r r5">
      <div class="panel-cols">
        <div>
          <h2>Recent Books</h2>
          <ul class="soft-list">
            <li><span class="sl-title">The Brothers Karamazov</span> <span class="sl-badge">reading now</span></li>
            <li><span class="sl-title">The Giver</span> <span class="sl-meta">Lowry</span></li>
            <li><span class="sl-title">We Who Wrestle with God</span> <span class="sl-meta">Peterson</span></li>
            <li><span class="sl-title">Welcome to the Universe</span> <span class="sl-meta">Tyson</span></li>
            <li><span class="sl-title">Ghost Town Living</span> <span class="sl-meta">Underwood</span></li>
            <li><span class="sl-title">Too Big to Fail</span> <span class="sl-meta">Sorkin</span></li>
            <li><span class="sl-title">The Order of Time</span> <span class="sl-meta">Rovelli</span></li>
          </ul>
        </div>
        <div>
          <h2>Favorite Albums</h2>
          <ul class="soft-list">
            <li><span class="sl-title">I'm The Problem</span> <span class="sl-meta">Wallen</span></li>
            <li><span class="sl-title">From A Room: Vol. 2</span> <span class="sl-meta">Stapleton</span></li>
            <li><span class="sl-title">Chief</span> <span class="sl-meta">Church</span></li>
            <li><span class="sl-title">Leather</span> <span class="sl-meta">Johnson</span></li>
            <li><span class="sl-title">From Elvis in Memphis</span> <span class="sl-meta">Presley</span></li>
            <li><span class="sl-title">What Are We Waiting For?</span> <span class="sl-meta">FK&amp;C</span></li>
            <li><span class="sl-title">Jars of Clay</span> <span class="sl-meta">Jars of Clay</span></li>
            <li><span class="sl-title">Summertime Blues</span> <span class="sl-meta">Bryan</span></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="panel r r6" id="blog">
      <h2>The Blog</h2>
      <p class="blog-note">No set purpose — random posts on random topics.</p>
      <div class="blog-item">
        <a href="/a-new-start/">A New Start</a>
        <time datetime="2025-10-25">Oct 25, 2025</time>
      </div>
    </div>

    <footer class="footer r r7">
      Powered by <a href="https://reimannlabs.com/">Reimann Labs</a>
    </footer>
  </div>
</body>
</html>
