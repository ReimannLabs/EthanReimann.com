---
/**
 * V4: OBSIDIAN — Dark Luxury aesthetic
 * Deep blacks, gold accents, dramatic typography, smooth animations,
 * premium feel with layered depth and refined restraint
 */
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Ethan Reimann – Obsidian</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #08080a;
      --surface: #111114;
      --surface-2: #1a1a1f;
      --border: #2a2a30;
      --text: #e8e6e3;
      --muted: #7a7872;
      --gold: #c9a84c;
      --gold-dim: rgba(201, 168, 76, 0.15);
      --gold-glow: 0 0 30px rgba(201, 168, 76, 0.08);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      font-size: clamp(0.95rem, 0.85rem + 0.4vw, 1.1rem);
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* Subtle noise overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 10000;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    ::selection { background: var(--gold); color: var(--black); }

    .page {
      max-width: 760px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .logo a { color: var(--text); text-decoration: none; }
    .logo span { color: var(--gold); }
    .nav {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 400;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav a:hover { color: var(--gold); }

    /* Hero */
    .hero {
      padding: 6rem 0 5rem;
      text-align: center;
      position: relative;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .hero-overline {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5em;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: clamp(2.8rem, 5vw + 1rem, 5.5rem);
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--text);
    }
    .hero-title em {
      font-style: italic;
      color: var(--gold);
    }

    /* About */
    .about-section {
      display: grid;
      grid-template-columns: 1fr 220px;
      gap: 3rem;
      align-items: start;
      padding: 4rem 0;
      border-bottom: 1px solid var(--border);
    }
    @media (max-width: 640px) {
      .about-section { grid-template-columns: 1fr; }
      .portrait-wrap { max-width: 240px; margin: 0 auto; }
    }
    .about-text p {
      margin-bottom: 1em;
      color: var(--text);
    }
    .about-text p:first-child::first-line {
      font-weight: 500;
    }

    .portrait-wrap {
      position: relative;
    }
    .portrait-wrap::before {
      content: '';
      position: absolute;
      inset: -8px;
      border: 1px solid var(--gold-dim);
      z-index: 0;
    }
    .portrait-wrap img {
      width: 100%;
      height: auto;
      display: block;
      filter: grayscale(1) contrast(1.1);
      position: relative;
      z-index: 1;
    }

    /* CTA */
    .cta-row {
      display: flex;
      justify-content: center;
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .gold-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.8em;
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      padding: 1em 2.5em;
      border: 1px solid var(--gold-dim);
      background: transparent;
      transition: all 0.35s;
    }
    .gold-btn:hover {
      background: var(--gold);
      color: var(--black);
      box-shadow: var(--gold-glow);
      border-color: var(--gold);
    }
    .gold-btn svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
    }

    /* Callout */
    .callout-block {
      background: var(--surface);
      border-left: 2px solid var(--gold);
      padding: 2rem 2.5rem;
      margin: 3rem 0;
      box-shadow: var(--gold-glow);
    }
    .callout-block strong {
      color: var(--gold);
      font-weight: 600;
      display: block;
      margin-bottom: 0.5em;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .callout-block p { color: var(--muted); line-height: 1.8; }

    /* Lists */
    .lists-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--border);
    }
    @media (max-width: 640px) {
      .lists-grid { grid-template-columns: 1fr; }
    }
    .list-block h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .list-block ul {
      list-style: none;
      padding: 0;
    }
    .list-block li {
      padding: 0.5em 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.92rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1em;
    }
    .list-block li:last-child { border-bottom: none; }
    .list-block .title { color: var(--text); }
    .list-block .meta {
      color: var(--muted);
      font-size: 0.8em;
      white-space: nowrap;
    }
    .list-block .badge {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold-dim);
      padding: 0.2em 0.6em;
      border-radius: 2px;
    }

    /* Blog */
    .blog-section {
      padding: 3rem 0;
    }
    .blog-section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.8em 0;
    }
    .blog-item a {
      color: var(--text);
      text-decoration: none;
      font-weight: 400;
      transition: color 0.3s;
    }
    .blog-item a:hover { color: var(--gold); }
    .blog-item time {
      color: var(--muted);
      font-size: 0.8rem;
      flex-shrink: 0;
    }

    /* Footer */
    .footer {
      padding: 2.5rem 0;
      border-top: 1px solid var(--border);
      text-align: center;
      color: var(--muted);
      font-size: 0.8rem;
      letter-spacing: 0.05em;
    }
    .footer a { color: var(--gold); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    /* Back */
    .back {
      position: fixed;
      top: 1em;
      right: 2em;
      z-index: 100000;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .back a { color: var(--muted); text-decoration: none; }
    .back a:hover { color: var(--gold); }

    /* Animations */
    @keyframes reveal {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .rv { animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .rv1 { animation-delay: 0.1s; }
    .rv2 { animation-delay: 0.2s; }
    .rv3 { animation-delay: 0.3s; }
    .rv4 { animation-delay: 0.4s; }
    .rv5 { animation-delay: 0.5s; }
    .rv6 { animation-delay: 0.6s; }
    .rv7 { animation-delay: 0.7s; }
    .rv8 { animation-delay: 0.8s; }
  </style>
</head>
<body>
  <div class="back"><a href="/">&#8592; Versions</a></div>
  <div class="page">
    <header class="header rv">
      <div class="logo"><a href="/v4/">Ethan<span>.</span>Reimann</a></div>
      <nav>
        <ul class="nav">
          <li><a href="/photography/">Photography</a></li>
          <li><a href="/projects/">Projects</a></li>
        </ul>
      </nav>
    </header>

    <section class="hero rv rv1">
      <p class="hero-overline">Personal Website</p>
      <h1 class="hero-title">Ethan<br /><em>Reimann</em></h1>
    </section>

    <section class="about-section rv rv2">
      <div class="about-text">
        <p>
          Hello World! This is one of my many attempts at a website in this
          modern world where personal websites are very uncommon. My name is
          none other than Ethan Reimann, a 10th grade student in the United
          States.
        </p>
        <p>
          You can find me and my work all across the internet, everything
          from YouTube videos to contributions to various GitHub projects.
        </p>
      </div>
      <div class="portrait-wrap">
        <img src="/portrait.jpg" alt="Ethan Reimann" width="220" height="293" />
      </div>
    </section>

    <div class="cta-row rv rv3">
      <a class="gold-btn" href="https://github.com/ReimannLabs">
        <svg viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <div class="callout-block rv rv4">
      <strong>Why Have a Personal Website in the 2020s?</strong>
      <p>
        Personal websites have always felt like a lost art to me. This site shall
        grow with time, as I find the time. In all honesty, I would rather my work
        be on a website owned by me rather than some billionaire social media platform.
      </p>
    </div>

    <div class="lists-grid rv rv5">
      <div class="list-block">
        <h2>Recent Books</h2>
        <ul>
          <li>
            <span class="title">The Brothers Karamazov</span>
            <span class="badge">Reading</span>
          </li>
          <li><span class="title">The Giver</span> <span class="meta">Lois Lowry</span></li>
          <li><span class="title">We Who Wrestle with God</span> <span class="meta">Peterson</span></li>
          <li><span class="title">Welcome to the Universe</span> <span class="meta">Tyson</span></li>
          <li><span class="title">Ghost Town Living</span> <span class="meta">Underwood</span></li>
          <li><span class="title">Too Big to Fail</span> <span class="meta">Sorkin</span></li>
          <li><span class="title">The Order of Time</span> <span class="meta">Rovelli</span></li>
        </ul>
      </div>
      <div class="list-block">
        <h2>Favorite Albums</h2>
        <ul>
          <li><span class="title">I'm The Problem</span> <span class="meta">Morgan Wallen</span></li>
          <li><span class="title">From A Room: Vol. 2</span> <span class="meta">Stapleton</span></li>
          <li><span class="title">Chief</span> <span class="meta">Eric Church</span></li>
          <li><span class="title">Leather</span> <span class="meta">Cody Johnson</span></li>
          <li><span class="title">From Elvis in Memphis</span> <span class="meta">Presley</span></li>
          <li><span class="title">What Are We Waiting For?</span> <span class="meta">FK&C</span></li>
          <li><span class="title">Jars of Clay</span> <span class="meta">Jars of Clay</span></li>
          <li><span class="title">Summertime Blues</span> <span class="meta">Zach Bryan</span></li>
        </ul>
      </div>
    </div>

    <div class="callout-block rv rv6">
      <strong>What I Write About on "The Blog"</strong>
      <p>
        There is no set purpose for my blog, I will likely treat it as a digital
        public journal. Posts will be written at random, and topics will be, well,
        also, random.
      </p>
    </div>

    <section class="blog-section rv rv7">
      <h2>The Blog</h2>
      <div class="blog-item">
        <a href="/a-new-start/">A New Start</a>
        <time datetime="2025-10-25">Oct 25, 2025</time>
      </div>
    </section>

    <footer class="footer rv rv8">
      <p>Powered by <a href="https://reimannlabs.com/">Reimann Labs</a></p>
    </footer>
  </div>
</body>
</html>
