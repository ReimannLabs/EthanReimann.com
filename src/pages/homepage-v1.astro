---
/**
 * VARIATION 1: "The Bento"
 * A dense, asymmetric bento-box grid layout. Every piece of content
 * is a different-sized tile. No traditional sections — the grid
 * IS the design. Inspired by Apple marketing pages meets
 * Japanese bento aesthetics.
 */

import AtelierLayout from '../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portraitOutside from '../images/ethan_portrait_outside.jpg';
import performingArts from '../images/ethan_performing_arts.jpg';
import vcfmw from '../images/ethan_VCFMW.jpg';
import portraitInside from '../images/ethan_new_portrait_inside.jpg';
import cameraDarkmirror from '../images/ethan_camera_darkmirror.JPG';

const books = [
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky', active: true },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AtelierLayout>
  <style>
    /* ── Blow out the default page container ── */
    .bento-wrapper {
      margin: 0 -2rem;
      padding: 0 1rem;
    }
    @media (min-width: 960px) {
      .bento-wrapper { margin: 0 -4rem; padding: 0; }
    }

    /* ── The Grid ─────────────────────────────── */
    .bento {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(80px, auto);
      gap: 0.6rem;
      padding-bottom: 2rem;
    }

    /* ── Tile base ────────────────────────────── */
    .tile {
      border-radius: 18px;
      overflow: hidden;
      position: relative;
    }
    .tile-padded {
      padding: 1.6rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* ── Color surfaces ──────────────────────── */
    .bg-warm { background: #b45309; color: #fff; }
    .bg-warm .tile-label { color: rgba(255,255,255,0.6); }
    .bg-warm a { color: #fff; }
    .bg-cream { background: #f5f0e8; color: var(--ink); }
    .bg-white { background: #fff; color: var(--ink); }
    .bg-ink { background: #1c1917; color: #fafaf8; }
    .bg-ink .tile-label { color: rgba(250,250,248,0.45); }
    .bg-ink a { color: #fafaf8; }
    .bg-light { background: rgba(180, 83, 9, 0.06); }
    .bg-photo { background: #e7e5e0; }

    /* ── Tile typography ─────────────────────── */
    .tile-label {
      font-size: 0.62rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin-bottom: 0.8rem;
    }
    .tile-big {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.025em;
    }
    .tile-big em { font-style: italic; }
    .tile-medium {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.15rem;
      line-height: 1.3;
    }
    .tile-body {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--ink);
    }
    .tile-body-light {
      font-size: 0.88rem;
      line-height: 1.65;
      color: rgba(250,250,248,0.8);
    }

    /* ── Stat tile ────────────────────────────── */
    .stat-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 3.2rem;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .stat-label {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 0.3rem;
    }
    .bg-warm .stat-label { color: rgba(255,255,255,0.65); }

    /* ── Photo tiles ─────────────────────────── */
    .tile-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .tile:hover .tile-photo {
      transform: scale(1.04);
    }

    /* ── Link tiles ──────────────────────────── */
    .tile-link {
      text-decoration: none;
      color: inherit;
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .tile-link:hover {
      transform: scale(0.97);
    }
    .tile-link .tile-arrow {
      font-size: 1.4rem;
      opacity: 0.4;
      transition: opacity 0.2s, transform 0.2s;
      display: block;
      margin-top: auto;
      text-align: right;
    }
    .tile-link:hover .tile-arrow {
      opacity: 1;
      transform: translateX(4px);
    }

    /* ── List items inside tiles ──────────────── */
    .tile-list { list-style: none; }
    .tile-list li {
      display: flex;
      justify-content: space-between;
      gap: 0.8em;
      padding: 0.35em 0;
      font-size: 0.82rem;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .tile-list li:last-child { border-bottom: none; }
    .tile-list .meta { color: var(--muted); font-size: 0.78em; text-align: right; white-space: nowrap; }
    .bg-ink .tile-list li { border-bottom-color: rgba(255,255,255,0.08); }
    .bg-ink .tile-list .meta { color: rgba(250,250,248,0.4); }
    .badge {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: rgba(180, 83, 9, 0.15);
      color: var(--warm);
      padding: 0.2em 0.6em;
      border-radius: 4px;
    }
    .bg-ink .badge { background: rgba(180, 83, 9, 0.3); color: #f5a623; }

    /* ── Blog items ──────────────────────────── */
    .blog-row {
      padding: 0.55em 0;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .blog-row:last-child { border-bottom: none; }
    .blog-row a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: color 0.15s;
    }
    .blog-row a:hover { color: var(--warm); }
    .blog-row time {
      display: block;
      font-size: 0.7rem;
      color: var(--muted);
      margin-top: 0.1em;
    }

    /* ── Placement ────────────────────────────── */
    /* Row 1: Hero (8 cols) + Portrait (4 cols) */
    .t-hero    { grid-column: 1 / 9;  grid-row: 1 / 4; }
    .t-portrait{ grid-column: 9 / 13; grid-row: 1 / 4; min-height: 320px; }

    /* Row 2: 4 nav tiles */
    .t-nav1 { grid-column: 1 / 4;  grid-row: 4 / 6; }
    .t-nav2 { grid-column: 4 / 7;  grid-row: 4 / 6; }
    .t-nav3 { grid-column: 7 / 10; grid-row: 4 / 6; }
    .t-nav4 { grid-column: 10 / 13; grid-row: 4 / 6; }

    /* Row 3: Bio (5 cols) + Photo (3 cols) + Stats (4 cols) */
    .t-bio   { grid-column: 1 / 6;  grid-row: 6 / 9; }
    .t-photo1{ grid-column: 6 / 9;  grid-row: 6 / 9; min-height: 240px; }
    .t-stats { grid-column: 9 / 13; grid-row: 6 / 7; }
    .t-stats2{ grid-column: 9 / 13; grid-row: 7 / 9; }

    /* Row 4: Photos (4 cols each) + callout (4 cols) */
    .t-photo2{ grid-column: 1 / 5; grid-row: 9 / 11; min-height: 220px; }
    .t-photo3{ grid-column: 5 / 9; grid-row: 9 / 11; min-height: 220px; }
    .t-callout{ grid-column: 9 / 13; grid-row: 9 / 11; }

    /* Row 5: Blog (6 cols) + Books (6 cols) */
    .t-blog  { grid-column: 1 / 7;  grid-row: 11 / 14; }
    .t-books { grid-column: 7 / 13; grid-row: 11 / 14; }

    /* Row 6: Albums full-width */
    .t-albums{ grid-column: 1 / 13; grid-row: 14 / 16; }

    /* ── Mobile: stack everything ─────────────── */
    @media (max-width: 700px) {
      .bento {
        grid-template-columns: 1fr 1fr;
        grid-auto-rows: auto;
      }
      .t-hero, .t-portrait,
      .t-bio, .t-callout,
      .t-blog, .t-books, .t-albums {
        grid-column: 1 / -1;
        grid-row: auto;
        min-height: unset;
      }
      .t-portrait { min-height: 280px; }
      .t-photo1, .t-photo2, .t-photo3 {
        grid-column: auto;
        grid-row: auto;
        min-height: 180px;
      }
      .t-nav1, .t-nav2, .t-nav3, .t-nav4 {
        grid-column: auto;
        grid-row: auto;
      }
      .t-stats, .t-stats2 {
        grid-column: auto;
        grid-row: auto;
      }
    }
  </style>

  <div class="bento-wrapper">
    <div class="bento">

      <!-- HERO -->
      <div class="tile tile-padded bg-cream t-hero f f2">
        <div>
          <p class="tile-label">Welcome</p>
          <h1 class="tile-big">This is <em>my digital home</em> — come on in.</h1>
        </div>
        <p class="tile-body" style="max-width: 480px; margin-top: 1.5rem;">
          I'm Ethan Reimann, a 10th grade student in the United States.
          You can find me and my work all across the internet — YouTube,
          GitHub, and right here. This site is home base.
        </p>
      </div>

      <!-- PORTRAIT -->
      <div class="tile bg-photo t-portrait f f2">
        <Image class="tile-photo" src={portraitOutside} alt="Ethan Reimann outdoors" width={600} quality={88} />
      </div>

      <!-- NAV TILES -->
      <a class="tile tile-padded tile-link bg-warm t-nav1 f f3" href="/photography/">
        <div>
          <p class="tile-label">Explore</p>
          <span class="tile-medium" style="color:#fff;">Photography</span>
        </div>
        <span class="tile-arrow">&rarr;</span>
      </a>
      <a class="tile tile-padded tile-link bg-ink t-nav2 f f3" href="/projects/">
        <div>
          <p class="tile-label">Explore</p>
          <span class="tile-medium" style="color:#fafaf8;">Projects</span>
        </div>
        <span class="tile-arrow">&rarr;</span>
      </a>
      <a class="tile tile-padded tile-link bg-white t-nav3 f f3" href="/blog/">
        <div>
          <p class="tile-label">Explore</p>
          <span class="tile-medium">The Blog</span>
        </div>
        <span class="tile-arrow">&rarr;</span>
      </a>
      <a class="tile tile-padded tile-link bg-cream t-nav4 f f3" href="https://github.com/ReimannLabs">
        <div>
          <p class="tile-label">Explore</p>
          <span class="tile-medium">GitHub</span>
        </div>
        <span class="tile-arrow">&rarr;</span>
      </a>

      <!-- BIO -->
      <div class="tile tile-padded bg-white t-bio f f4">
        <div>
          <p class="tile-label">About Me</p>
          <p class="tile-body" style="margin-bottom:0.8em;">
            I'm 16 years old, born July 2009. Currently a 10th grade
            student interested in pursuing Economics, Music, or Finance.
          </p>
          <p class="tile-body">
            My hobbies span Theatre, Music (Vocal &amp; Composition),
            Software Engineering, 4&#8209;H, and Writing. I run
            <a href="https://reimannlabs.com/" style="color:var(--warm);text-decoration:none;font-weight:500;">Reimann Labs</a>
            and a handful of other projects.
          </p>
        </div>
        <p style="font-size:0.8rem;color:var(--muted);margin-top:1rem;">
          <a href="mailto:hello@ethanreimann.com" style="color:var(--warm);text-decoration:none;">hello@ethanreimann.com</a>
        </p>
      </div>

      <!-- PHOTO 1 -->
      <div class="tile bg-photo t-photo1 f f4">
        <Image class="tile-photo" src={performingArts} alt="Ethan on stage" width={500} quality={82} />
      </div>

      <!-- STAT -->
      <div class="tile tile-padded bg-warm t-stats f f4" style="justify-content:center;align-items:center;text-align:center;">
        <div>
          <span class="stat-num" style="color:#fff;">16</span>
          <p class="stat-label">years old</p>
        </div>
      </div>

      <!-- STAT 2 -->
      <div class="tile tile-padded bg-light t-stats2 f f4" style="justify-content:center;align-items:center;text-align:center;">
        <div>
          <span class="stat-num" style="color:var(--warm);">10th</span>
          <p class="stat-label">Grade</p>
        </div>
      </div>

      <!-- PHOTO 2 -->
      <div class="tile bg-photo t-photo2 f f5">
        <Image class="tile-photo" src={vcfmw} alt="Vintage Computer Festival" width={500} quality={82} />
      </div>

      <!-- PHOTO 3 -->
      <div class="tile bg-photo t-photo3 f f5">
        <Image class="tile-photo" src={cameraDarkmirror} alt="Ethan with camera" width={500} quality={82} />
      </div>

      <!-- CALLOUT -->
      <div class="tile tile-padded bg-ink t-callout f f5">
        <p class="tile-label">Manifesto</p>
        <p class="tile-body-light" style="font-family:'Fraunces',serif;font-style:italic;font-size:0.95rem;line-height:1.6;">
          "Personal websites have always felt like a lost art. I would rather
          my work be on a website owned by me rather than some billionaire
          social media platform."
        </p>
      </div>

      <!-- BLOG -->
      <div class="tile tile-padded bg-white t-blog f f6">
        <div>
          <p class="tile-label">Latest Writing</p>
          {sortedPosts.map((post) => (
            <div class="blog-row">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
          ))}
        </div>
      </div>

      <!-- BOOKS -->
      <div class="tile tile-padded bg-cream t-books f f6">
        <div>
          <p class="tile-label">Bookshelf</p>
          <ul class="tile-list">
            {books.map((b) => (
              <li>
                <span>{b.title}</span>
                {b.active ? <span class="badge">Reading</span> : <span class="meta">{b.author}</span>}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- ALBUMS -->
      <div class="tile tile-padded bg-ink t-albums f f7">
        <div>
          <p class="tile-label">On Rotation</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.3rem 2rem;">
            {albums.map((a) => (
              <div style="display:flex;justify-content:space-between;gap:0.8em;padding:0.3em 0;font-size:0.82rem;border-bottom:1px solid rgba(255,255,255,0.06);">
                <span style="color:#fafaf8;">{a.title}</span>
                <span style="color:rgba(250,250,248,0.4);font-size:0.78em;white-space:nowrap;">{a.artist}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</AtelierLayout>
