---
/**
 * V2: FOLIO — Classic book / codex aesthetic
 * Rich warm tones, table-of-contents sidebar feel, "chapters" of a digital life.
 * Feels like thumbing through a beautifully typeset personal almanac.
 * Inspired by old Penguin paperbacks and letterpress printing.
 */
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Ethan Reimann — Folio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,600;0,7..72,700;1,7..72,400&family=Nanum+Myeongjo:wght@400;700&family=Inconsolata:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f7f3eb;
      --paper: #fffdf7;
      --ink: #2b2520;
      --brown: #6d5d4b;
      --accent: #9b4d2b;
      --rule: #d4cdbf;
      --faded: #a69d8e;
    }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: 'Literata', Georgia, serif;
      font-size: clamp(0.95rem, 0.85rem + 0.4vw, 1.1rem);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: var(--accent); color: var(--cream); }

    /* Two-column codex layout */
    .codex {
      display: grid;
      grid-template-columns: 220px 1fr;
      max-width: 960px;
      margin: 0 auto;
      min-height: 100vh;
    }
    @media (max-width: 768px) {
      .codex { grid-template-columns: 1fr; }
      .sidebar { position: relative; border-right: none; border-bottom: 1px solid var(--rule); }
      .sidebar-inner { position: relative; top: auto; }
    }

    /* Sidebar — table of contents */
    .sidebar {
      border-right: 1px solid var(--rule);
      background: var(--cream);
      position: relative;
    }
    .sidebar-inner {
      position: sticky;
      top: 0;
      padding: 2.5rem 1.5rem;
    }
    .sidebar-title {
      font-family: 'Nanum Myeongjo', serif;
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.3em;
      line-height: 1.3;
    }
    .sidebar-title a { color: var(--ink); text-decoration: none; }
    .sidebar-sub {
      font-size: 0.72rem;
      color: var(--faded);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 2em;
      font-family: 'Inconsolata', monospace;
    }
    .toc { list-style: none; }
    .toc li { margin-bottom: 0.3em; }
    .toc a {
      color: var(--brown);
      text-decoration: none;
      font-size: 0.85rem;
      display: flex;
      align-items: baseline;
      gap: 0.5em;
      transition: color 0.2s;
    }
    .toc a:hover { color: var(--accent); }
    .toc .num {
      font-family: 'Inconsolata', monospace;
      font-size: 0.7rem;
      color: var(--faded);
      min-width: 2em;
    }
    .toc-divider {
      border: none;
      border-top: 1px dotted var(--rule);
      margin: 1em 0;
    }
    .toc-section-label {
      font-family: 'Inconsolata', monospace;
      font-size: 0.6rem;
      color: var(--faded);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 0.5em;
    }

    /* Main body — the "pages" */
    .body {
      background: var(--paper);
      padding: 2.5rem 3rem;
      min-height: 100vh;
    }
    @media (max-width: 768px) {
      .body { padding: 2rem 1.5rem; }
    }

    /* Chapter marker */
    .chapter {
      margin-bottom: 3rem;
      scroll-margin-top: 2rem;
    }
    .chapter-num {
      font-family: 'Inconsolata', monospace;
      font-size: 0.65rem;
      color: var(--faded);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    .chapter h2 {
      font-family: 'Nanum Myeongjo', serif;
      font-weight: 700;
      font-size: 1.3rem;
      margin-bottom: 0.8em;
      padding-bottom: 0.5em;
      border-bottom: 2px solid var(--ink);
      line-height: 1.4;
    }

    /* Opening — hero */
    .opening {
      margin-bottom: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--rule);
    }
    .opening-title {
      font-family: 'Nanum Myeongjo', serif;
      font-weight: 700;
      font-size: clamp(1.8rem, 3vw + 0.5rem, 2.8rem);
      line-height: 1.15;
      margin-bottom: 0.5em;
    }
    .opening-title em { font-style: italic; color: var(--accent); }
    .opening-edition {
      font-family: 'Inconsolata', monospace;
      font-size: 0.7rem;
      color: var(--faded);
      letter-spacing: 0.1em;
    }

    /* About */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 160px;
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 560px) {
      .about-grid { grid-template-columns: 1fr; }
      .portrait { max-width: 160px; }
    }
    .about-text p {
      text-align: justify;
      hyphens: auto;
      margin-bottom: 1em;
    }
    .about-text p:first-child::first-letter {
      font-family: 'Nanum Myeongjo', serif;
      font-weight: 700;
      float: left;
      font-size: 3.5em;
      line-height: 0.8;
      margin-right: 0.06em;
      margin-top: 0.08em;
      color: var(--accent);
    }
    .portrait {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      filter: sepia(20%) contrast(1.05);
      border: 1px solid var(--rule);
      padding: 4px;
      background: var(--cream);
    }

    /* Callout block */
    .aside {
      background: var(--cream);
      border: 1px solid var(--rule);
      padding: 1.5rem 2rem;
      margin: 2rem 0;
      font-size: 0.92rem;
    }
    .aside strong { color: var(--accent); }
    .aside p { color: var(--brown); }

    /* Catalogue lists */
    .catalogue ul { list-style: none; }
    .catalogue li {
      padding: 0.35em 0;
      border-bottom: 1px dotted var(--rule);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1em;
      font-size: 0.92rem;
    }
    .catalogue li:last-child { border-bottom: none; }
    .cat-title { color: var(--ink); }
    .cat-meta { color: var(--faded); font-size: 0.82em; font-style: italic; white-space: nowrap; }
    .cat-badge {
      font-family: 'Inconsolata', monospace;
      font-size: 0.6rem;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 0.1em 0.5em;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* Github link */
    .cta {
      text-align: center;
      margin: 2rem 0;
    }
    .folio-btn {
      display: inline-block;
      font-family: 'Inconsolata', monospace;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--ink);
      padding: 0.8em 2.5em;
      text-decoration: none;
      transition: all 0.2s;
    }
    .folio-btn:hover { background: var(--accent); }

    /* Blog entry */
    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5em 0;
    }
    .blog-item a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 600;
    }
    .blog-item a:hover { color: var(--accent); }
    .blog-item time {
      font-family: 'Inconsolata', monospace;
      font-size: 0.75rem;
      color: var(--faded);
    }

    /* Colophon */
    .colophon {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 2px solid var(--ink);
      text-align: center;
      font-family: 'Inconsolata', monospace;
      font-size: 0.7rem;
      color: var(--faded);
      letter-spacing: 0.06em;
    }
    .colophon a { color: var(--accent); text-decoration: none; }

    /* Nav link pages */
    .page-links { list-style: none; margin: 1em 0; }
    .page-links li {
      border-bottom: 1px solid var(--rule);
    }
    .page-links a {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7em 0;
      color: var(--ink);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s;
    }
    .page-links a:hover { color: var(--accent); }
    .page-links .arrow { color: var(--faded); font-size: 0.9em; transition: transform 0.2s; }
    .page-links a:hover .arrow { transform: translateX(3px); color: var(--accent); }
    .page-links .page-desc {
      display: block;
      font-weight: 400;
      font-size: 0.8rem;
      color: var(--faded);
      margin-top: 0.1em;
    }

    /* Back */
    .back { position: fixed; top: 1.2em; right: 2em; z-index: 1000; font-size: 0.75rem; font-family: 'Inconsolata', monospace; }
    .back a { color: var(--faded); text-decoration: none; }
    .back a:hover { color: var(--accent); }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fi { animation: fadeIn 0.6s ease both; }
    .d1 { animation-delay: 0.05s; } .d2 { animation-delay: 0.12s; }
    .d3 { animation-delay: 0.2s; } .d4 { animation-delay: 0.28s; }
    .d5 { animation-delay: 0.36s; } .d6 { animation-delay: 0.44s; }
    .d7 { animation-delay: 0.52s; }
  </style>
</head>
<body>
  <div class="back"><a href="/">&larr; versions</a></div>
  <div class="codex">
    <aside class="sidebar fi d1">
      <div class="sidebar-inner">
        <h1 class="sidebar-title"><a href="/v2/">Ethan Reimann</a></h1>
        <p class="sidebar-sub">Personal Folio, 2025 ed.</p>

        <p class="toc-section-label">Pages</p>
        <ul class="toc">
          <li><a href="/photography/"><span class="num">01</span> Photography</a></li>
          <li><a href="/projects/"><span class="num">02</span> Projects</a></li>
          <li><a href="https://github.com/ReimannLabs"><span class="num">03</span> GitHub</a></li>
        </ul>

        <hr class="toc-divider" />
        <p class="toc-section-label">This Page</p>
        <ul class="toc">
          <li><a href="#about"><span class="num">i</span> About</a></li>
          <li><a href="#reading"><span class="num">ii</span> Reading</a></li>
          <li><a href="#listening"><span class="num">iii</span> Listening</a></li>
          <li><a href="#journal"><span class="num">iv</span> Journal</a></li>
        </ul>
      </div>
    </aside>

    <main class="body">
      <div class="opening fi d2">
        <p class="opening-edition">First Edition — October 2025</p>
        <h2 class="opening-title">The Personal Folio of<br /><em>Ethan Reimann</em></h2>
      </div>

      <section class="chapter fi d3" id="about">
        <p class="chapter-num">Chapter I</p>
        <h2>About the Author</h2>
        <div class="about-grid">
          <div class="about-text">
            <p>
              Hello World! This is one of my many attempts at a website in this
              modern world where personal websites are very uncommon. My name is
              none other than Ethan Reimann, a 10th grade student in the United
              States. You can find me and my work all across the internet,
              everything from YouTube videos to contributions to various GitHub
              projects.
            </p>
          </div>
          <img class="portrait" src="/portrait.jpg" alt="Ethan Reimann" width="160" height="213" />
        </div>

        <div class="aside">
          <strong>Why Have a Personal Website in the 2020s?</strong><br />
          <p>
            Personal websites have always felt like a lost art. I would rather
            my work be on a website owned by me rather than some billionaire
            social media platform. This site shall grow with time.
          </p>
        </div>

        <div class="cta">
          <a class="folio-btn" href="https://github.com/ReimannLabs">View on GitHub</a>
        </div>
      </section>

      <section class="chapter catalogue fi d4" id="explore">
        <p class="chapter-num">Explore</p>
        <h2>Pages &amp; Sections</h2>
        <ul class="page-links">
          <li>
            <a href="/photography/">
              <span>Photography<span class="page-desc">Moments captured through the lens</span></span>
              <span class="arrow">&rarr;</span>
            </a>
          </li>
          <li>
            <a href="/projects/">
              <span>Projects<span class="page-desc">Things I've built and contributed to</span></span>
              <span class="arrow">&rarr;</span>
            </a>
          </li>
        </ul>
      </section>

      <section class="chapter catalogue fi d5" id="reading">
        <p class="chapter-num">Chapter II</p>
        <h2>Recent Reading</h2>
        <ul>
          <li><span class="cat-title">The Brothers Karamazov</span> <span class="cat-badge">Reading</span></li>
          <li><span class="cat-title">The Giver</span> <span class="cat-meta">Lois Lowry</span></li>
          <li><span class="cat-title">We Who Wrestle with God</span> <span class="cat-meta">Jordan Peterson</span></li>
          <li><span class="cat-title">Welcome to the Universe</span> <span class="cat-meta">Tyson, Et al.</span></li>
          <li><span class="cat-title">Ghost Town Living</span> <span class="cat-meta">Brent Underwood</span></li>
          <li><span class="cat-title">Too Big to Fail</span> <span class="cat-meta">Andrew Sorkin</span></li>
          <li><span class="cat-title">The Order of Time</span> <span class="cat-meta">Carlo Rovelli</span></li>
        </ul>
      </section>

      <section class="chapter catalogue fi d6" id="listening">
        <p class="chapter-num">Chapter III</p>
        <h2>Favorite Albums</h2>
        <ul>
          <li><span class="cat-title">I'm The Problem</span> <span class="cat-meta">Morgan Wallen</span></li>
          <li><span class="cat-title">From A Room: Volume 2</span> <span class="cat-meta">Chris Stapleton</span></li>
          <li><span class="cat-title">Chief</span> <span class="cat-meta">Eric Church</span></li>
          <li><span class="cat-title">Leather</span> <span class="cat-meta">Cody Johnson</span></li>
          <li><span class="cat-title">From Elvis in Memphis</span> <span class="cat-meta">Elvis Presley</span></li>
          <li><span class="cat-title">What Are We Waiting For?</span> <span class="cat-meta">For King &amp; Country</span></li>
          <li><span class="cat-title">Jars of Clay</span> <span class="cat-meta">Jars of Clay</span></li>
          <li><span class="cat-title">Summertime Blues</span> <span class="cat-meta">Zach Bryan</span></li>
        </ul>
      </section>

      <section class="chapter fi d7" id="journal">
        <p class="chapter-num">Chapter IV</p>
        <h2>The Journal</h2>
        <p style="color: var(--brown); font-size: 0.9rem; font-style: italic; margin-bottom: 1em;">
          No set purpose — a digital public journal. Random posts on random topics.
        </p>
        <div class="blog-item">
          <a href="/a-new-start/">A New Start</a>
          <time datetime="2025-10-25">Oct 25, 2025</time>
        </div>
      </section>

      <div class="colophon fi d7">
        <p>Typeset digitally &middot; Powered by <a href="https://reimannlabs.com/">Reimann Labs</a> &middot; MMXXV</p>
      </div>
    </main>
  </div>
</body>
</html>
