---
/**
 * V1: ATELIER — Gallery / Digital Home
 * A clean, airy space with prominent navigation to Photography, Projects, Files.
 * Feels like walking into a well-lit studio. Generous whitespace, refined grid,
 * large nav tiles that invite exploration. Classic modern with warmth.
 */

const rooms = [
  { name: 'Photography', href: '/photography/', icon: '&#9634;', desc: 'Moments captured through the lens' },
  { name: 'Projects', href: '/projects/', icon: '&#9648;', desc: 'Things I\'ve built and contributed to' },
  { name: 'The Blog', href: '#blog', icon: '&#9998;', desc: 'A digital public journal' },
  { name: 'GitHub', href: 'https://github.com/ReimannLabs', icon: '&#10070;', desc: 'Open source work and code' },
];

const books = [
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky', active: true },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Ethan Reimann — Atelier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Karla:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #fafaf8;
      --surface: #ffffff;
      --ink: #1c1917;
      --muted: #78716c;
      --border: #e7e5e0;
      --warm: #b45309;
      --warm-light: rgba(180, 83, 9, 0.06);
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Karla', sans-serif;
      font-size: clamp(0.9rem, 0.8rem + 0.4vw, 1.05rem);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: var(--warm); color: white; }

    .page { max-width: 900px; margin: 0 auto; padding: 0 2rem; }

    /* Header — minimal, confident */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 2.5rem 0;
    }
    .logo {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
    }
    .logo a { color: var(--ink); text-decoration: none; }
    .header-nav { display: flex; gap: 1.5rem; list-style: none; }
    .header-nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 400;
      transition: color 0.2s;
    }
    .header-nav a:hover { color: var(--ink); }

    /* Hero — large, warm, inviting */
    .hero {
      padding: 4rem 0;
      border-bottom: 1px solid var(--border);
    }
    .hero-greeting {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--warm);
      margin-bottom: 1em;
    }
    .hero-title {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(2.2rem, 4vw + 0.8rem, 3.8rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      max-width: 600px;
    }
    .hero-title em {
      font-style: italic;
      color: var(--warm);
    }

    /* About with portrait */
    .intro {
      display: grid;
      grid-template-columns: 1fr 200px;
      gap: 3rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }
    @media (max-width: 640px) {
      .intro { grid-template-columns: 1fr; }
      .portrait { max-width: 180px; }
    }
    .intro p { color: var(--ink); margin-bottom: 1em; }
    .intro p:last-child { margin-bottom: 0; }
    .portrait {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      border-radius: 6px;
      filter: grayscale(15%);
    }

    /* Room tiles — the "digital home" navigation */
    .rooms {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin: 3rem 0;
    }
    @media (max-width: 520px) {
      .rooms { grid-template-columns: 1fr; }
    }
    .room {
      background: var(--surface);
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.5em;
      transition: background 0.2s;
    }
    .room:hover { background: var(--warm-light); }
    .room-icon {
      font-size: 1.5rem;
      color: var(--warm);
      line-height: 1;
    }
    .room-name {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.05rem;
    }
    .room-desc {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* Callout */
    .callout {
      background: var(--warm-light);
      border-left: 3px solid var(--warm);
      padding: 1.5rem 2rem;
      margin: 3rem 0;
      border-radius: 0 6px 6px 0;
    }
    .callout strong {
      font-family: 'Fraunces', serif;
      display: block;
      margin-bottom: 0.3em;
      font-size: 0.95rem;
    }
    .callout p { color: var(--muted); font-size: 0.9rem; }

    /* Lists — side by side */
    .lists {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--border);
    }
    @media (max-width: 640px) { .lists { grid-template-columns: 1fr; gap: 2rem; } }
    .list-section h2 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .list-section ul { list-style: none; }
    .list-section li {
      padding: 0.4em 0;
      font-size: 0.9rem;
      display: flex;
      justify-content: space-between;
      gap: 1em;
      border-bottom: 1px solid var(--bg);
    }
    .list-section li:last-child { border-bottom: none; }
    .list-title { color: var(--ink); }
    .list-meta { color: var(--muted); font-size: 0.82em; text-align: right; white-space: nowrap; }
    .badge {
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--warm);
      background: var(--warm-light);
      padding: 0.15em 0.6em;
      border-radius: 3px;
    }

    /* Blog */
    .blog { padding: 3rem 0; }
    .blog h2 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .blog-note {
      color: var(--muted);
      font-size: 0.85rem;
      font-style: italic;
      margin-bottom: 1em;
    }
    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.6em 0;
    }
    .blog-item a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }
    .blog-item a:hover { color: var(--warm); }
    .blog-item time { color: var(--muted); font-size: 0.82rem; }

    /* Footer */
    .footer {
      padding: 2rem 0;
      border-top: 1px solid var(--border);
      text-align: center;
      color: var(--muted);
      font-size: 0.8rem;
    }
    .footer a { color: var(--warm); text-decoration: none; }
    .footer a:hover { text-decoration: underline; }

    /* Back */
    .back { position: fixed; top: 1.2em; right: 2em; z-index: 1000; font-size: 0.8rem; }
    .back a { color: var(--muted); text-decoration: none; }
    .back a:hover { color: var(--warm); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .f { animation: fadeUp 0.65s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .f1 { animation-delay: 0.05s; } .f2 { animation-delay: 0.1s; }
    .f3 { animation-delay: 0.18s; } .f4 { animation-delay: 0.26s; }
    .f5 { animation-delay: 0.34s; } .f6 { animation-delay: 0.42s; }
    .f7 { animation-delay: 0.5s; }
  </style>
</head>
<body>
  <div class="back"><a href="/">&larr; versions</a></div>
  <div class="page">
    <header class="header f f1">
      <div class="logo"><a href="/v1/">Ethan Reimann</a></div>
      <nav>
        <ul class="header-nav">
          <li><a href="/photography/">Photography</a></li>
          <li><a href="/projects/">Projects</a></li>
        </ul>
      </nav>
    </header>

    <section class="hero f f2">
      <p class="hero-greeting">Welcome to my corner of the internet</p>
      <h1 class="hero-title">This is <em>my digital home</em> — come on in.</h1>
    </section>

    <section class="intro f f3">
      <div>
        <p>
          Hello World! I'm Ethan Reimann, a 10th grade student in the United
          States. This is one of my many attempts at a website in this modern
          world where personal websites are very uncommon.
        </p>
        <p>
          You can find me and my work all across the internet — everything from
          YouTube videos to contributions to various GitHub projects. This site
          is the home base for all of it.
        </p>
      </div>
      <img class="portrait" src="/portrait.jpg" alt="Ethan Reimann" width="200" height="267" />
    </section>

    <div class="rooms f f4">
      {rooms.map((room) => (
        <a class="room" href={room.href}>
          <span class="room-icon" set:html={room.icon} />
          <span class="room-name">{room.name}</span>
          <span class="room-desc">{room.desc}</span>
        </a>
      ))}
    </div>

    <div class="callout f f5">
      <strong>Why Have a Personal Website in the 2020s?</strong>
      <p>
        Personal websites have always felt like a lost art. I would rather my work
        be on a website owned by me rather than some billionaire social media platform.
        This site shall grow with time.
      </p>
    </div>

    <div class="lists f f5">
      <div class="list-section">
        <h2>Recent Books</h2>
        <ul>
          {books.map((b) => (
            <li>
              <span class="list-title">{b.title}</span>
              {b.active ? <span class="badge">Reading</span> : <span class="list-meta">{b.author}</span>}
            </li>
          ))}
        </ul>
      </div>
      <div class="list-section">
        <h2>Favorite Albums</h2>
        <ul>
          {albums.map((a) => (
            <li>
              <span class="list-title">{a.title}</span>
              <span class="list-meta">{a.artist}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <section class="blog f f6" id="blog">
      <h2>The Blog</h2>
      <p class="blog-note">
        No set purpose — a digital public journal. Random posts, random topics.
      </p>
      <div class="blog-item">
        <a href="/a-new-start/">A New Start</a>
        <time datetime="2025-10-25">Oct 25, 2025</time>
      </div>
    </section>

    <footer class="footer f f7">
      Powered by <a href="https://reimannlabs.com/">Reimann Labs</a>
    </footer>
  </div>
</body>
</html>
