---
/**
 * HOMEPAGE — "The Gazette Grid"
 * Bento grid layout with stamp/zine editorial details.
 */

import AtelierLayout from '../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portraitOutside from '../images/ethan_portrait_outside.jpg';
import performingArts from '../images/theatre/ethan-frankenguest-dear-edwina-2026.jpg';
import vcfmw from '../images/ethan_VCFMW.jpg';
import portraitInside from '../images/ethan_new_portrait_inside.jpg';
import cameraDarkmirror from '../images/ethan_camera_darkmirror.JPG';

const books = [
  { title: 'The Great Gatsby', author: 'F. Scott Fitzgerald', active: true },
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky' },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AtelierLayout>
  <style>
    /* ── Expand beyond .page container ────────── */
    .grid-wrapper {
      margin: 0 -2rem;
      padding: 0 0.75rem;
    }
    @media (min-width: 960px) {
      .grid-wrapper { margin: 0 -4rem; padding: 0; }
    }

    /* ═══ THE GRID ═══ */
    .grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(70px, auto);
      gap: 0.5rem;
      padding-bottom: 0.5rem;
    }

    /* ── Tile base ── */
    .tile {
      border-radius: 8px;
      overflow: hidden;
      position: relative;
      border: 2px solid var(--ink);
    }
    .tile-pad {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* ── Surfaces ── */
    .s-cream  { background: #f5f0e8; color: var(--ink); }
    .s-white  { background: #fff; color: var(--ink); }
    .s-warm   { background: #b45309; color: #fff; border-color: #8a3a04; }
    .s-ink    { background: #1c1917; color: #fafaf8; border-color: #1c1917; }
    .s-light  { background: rgba(180, 83, 9, 0.05); }
    .s-photo  { border-color: var(--ink); }

    /* ── Stamp badge ── */
    .stamp {
      display: inline-block;
      border: 2.5px solid currentColor;
      padding: 0.25em 0.7em;
      font-size: 0.58rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      position: relative;
      line-height: 1.4;
    }
    .stamp::after {
      content: '';
      position: absolute;
      inset: 2.5px;
      border: 1px solid currentColor;
    }
    .stamp-warm { color: var(--warm); }
    .stamp-ink  { color: var(--ink); }
    .stamp-light{ color: rgba(250,250,248,0.5); }
    .stamp-tilt { transform: rotate(-2.5deg); }

    /* ── Tag ── */
    .tag {
      display: inline-block;
      background: var(--ink);
      color: #fafaf8;
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.3em 0.65em;
      border-radius: 2px;
    }
    .tag-warm { background: var(--warm); }

    /* ── Tile label ── */
    .t-label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin-bottom: 0.7rem;
    }
    .s-ink .t-label  { color: rgba(250,250,248,0.4); }
    .s-warm .t-label { color: rgba(255,255,255,0.55); }

    /* ═══ HERO ═══ */
    .hero-pre {
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--muted);
      margin-bottom: 0.8rem;
    }
    .hero-title {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 0.95;
      letter-spacing: -0.035em;
      text-transform: uppercase;
    }
    .hero-title .line-accent {
      display: block;
      color: var(--warm);
      font-style: italic;
      text-transform: none;
      font-weight: 400;
      margin-top: 0.05em;
    }
    .hero-body {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--ink);
      max-width: 440px;
      margin-top: 1.2rem;
    }
    .hero-stamp-wrap { margin-top: 1.2rem; }

    /* ═══ PHOTOS ═══ */
    .tile-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .tile:hover .tile-photo { transform: scale(1.05); }
    .photo-label {
      position: absolute;
      bottom: 0.8rem;
      left: 0.8rem;
      z-index: 2;
    }

    /* ═══ NAV TILES ═══ */
    .nav-tile {
      text-decoration: none;
      color: inherit;
      transition: background 0.2s, color 0.2s;
    }
    .nav-tile:hover { background: var(--ink); color: #fafaf8; }
    .nav-tile:hover .nav-num { color: var(--warm); }
    .nav-tile:hover .nav-desc { color: rgba(250,250,248,0.5); }
    .nav-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 2rem;
      line-height: 1;
      color: var(--border);
      transition: color 0.2s;
    }
    .nav-name {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.05rem;
      margin-top: 0.25rem;
      display: block;
    }
    .nav-desc {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.15rem;
      transition: color 0.2s;
    }

    /* ═══ STATS ═══ */
    .stat-center {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 1rem;
    }
    .stat-center > div {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .stat-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 3rem;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .stat-sub {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.25rem;
      color: var(--muted);
    }
    .s-warm .stat-sub { color: rgba(255,255,255,0.6); }
    .s-ink .stat-num  { color: var(--warm); }
    .s-ink .stat-sub  { color: rgba(250,250,248,0.4); }

    /* ═══ BIO ═══ */
    .bio-body {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--ink);
      margin-bottom: 1rem;
    }
    .bio-row {
      display: flex;
      gap: 1rem;
      padding: 0.4em 0;
      border-bottom: 1px dashed var(--border);
      font-size: 0.85rem;
    }
    .bio-row:last-child { border-bottom: none; }
    .bio-key {
      font-weight: 700;
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--warm);
      min-width: 65px;
      flex-shrink: 0;
      padding-top: 0.15em;
    }
    .bio-val { color: var(--ink); }
    .bio-val a { color: var(--warm); text-decoration: none; }
    .bio-val a:hover { text-decoration: underline; }

    /* ═══ BLOG ═══ */
    .blog-row {
      display: grid;
      grid-template-columns: 2.2em 1fr auto;
      gap: 0.6rem;
      align-items: baseline;
      padding: 0.55em 0;
      border-bottom: 1.5px solid var(--border);
    }
    .blog-row:last-child { border-bottom: none; }
    .blog-row:first-child { border-top: 1.5px solid var(--border); }
    .blog-num {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--border);
    }
    .blog-row a {
      color: var(--ink);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: color 0.15s;
    }
    .blog-row a:hover { color: var(--warm); }
    .blog-row time {
      font-size: 0.7rem;
      color: var(--muted);
      white-space: nowrap;
    }

    /* ═══ LISTS ═══ */
    .list-item {
      display: flex;
      justify-content: space-between;
      gap: 0.8em;
      padding: 0.35em 0;
      font-size: 0.82rem;
      border-bottom: 1px dashed var(--border);
    }
    .list-item:last-child { border-bottom: none; }
    .list-title { color: var(--ink); }
    .list-meta {
      color: var(--muted);
      font-size: 0.78em;
      text-align: right;
      white-space: nowrap;
    }
    .s-ink .list-item { border-bottom-color: rgba(255,255,255,0.08); }
    .s-ink .list-title { color: #fafaf8; }
    .s-ink .list-meta  { color: rgba(250,250,248,0.4); }
    .badge {
      font-size: 0.55rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
      background: var(--warm);
      padding: 0.2em 0.6em;
      border-radius: 2px;
    }
    .s-ink .badge { background: rgba(180, 83, 9, 0.4); color: #f5a623; }

    /* ═══ MANIFESTO ═══ */
    .manifesto-text {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(250,250,248,0.8);
    }
    .manifesto-footer { margin-top: 1.2rem; }

    /* ═══ GRID PLACEMENT ═══ */
    .g-hero     { grid-column: 1 / 9;   grid-row: 1 / 5; }
    .g-portrait { grid-column: 9 / 13;  grid-row: 1 / 5; min-height: 360px; }
    .g-nav1 { grid-column: 1 / 4;   grid-row: 5 / 7; }
    .g-nav2 { grid-column: 4 / 7;   grid-row: 5 / 7; }
    .g-nav3 { grid-column: 7 / 10;  grid-row: 5 / 7; }
    .g-nav4 { grid-column: 10 / 13; grid-row: 5 / 7; }
    .g-bio    { grid-column: 1 / 6;  grid-row: 7 / 10; }
    .g-photo1 { grid-column: 6 / 9;  grid-row: 7 / 10; min-height: 260px; }
    .g-stat1  { grid-column: 9 / 13; grid-row: 7 / 8; }
    .g-stat2  { grid-column: 9 / 13; grid-row: 8 / 10; }
    .g-photo2    { grid-column: 1 / 5;  grid-row: 10 / 12; min-height: 220px; }
    .g-photo3    { grid-column: 5 / 9;  grid-row: 10 / 12; min-height: 220px; }
    .g-manifesto { grid-column: 9 / 13; grid-row: 10 / 12; }
    .g-blog  { grid-column: 1 / 7;  grid-row: 12 / 15; }
    .g-books { grid-column: 7 / 13; grid-row: 12 / 15; }
    .g-albums { grid-column: 1 / 13; grid-row: 15 / 17; }

    /* ═══ MOBILE ═══ */
    @media (max-width: 700px) {
      .grid-wrapper {
        margin: 0;
        padding: 0;
      }
      .grid {
        grid-template-columns: 1fr 1fr;
        grid-auto-rows: auto;
      }
      .g-hero, .g-portrait,
      .g-bio, .g-manifesto,
      .g-blog, .g-books, .g-albums {
        grid-column: 1 / -1;
        grid-row: auto;
        min-height: unset;
      }
      .g-portrait { min-height: 300px; }
      .g-photo1, .g-photo2, .g-photo3 {
        grid-column: auto;
        grid-row: auto;
        min-height: 180px;
      }
      .g-nav1, .g-nav2, .g-nav3, .g-nav4 {
        grid-column: auto;
        grid-row: auto;
      }
      .g-stat1, .g-stat2 {
        grid-column: auto;
        grid-row: auto;
      }
    }
  </style>

  <div class="grid-wrapper">
    <div class="grid">

      <!-- ═══ HERO ═══ -->
      <div class="tile tile-pad s-cream g-hero f f2">
        <div>
          <p class="hero-pre">Issue No. 1 &mdash; Personal Website</p>
          <h1 class="hero-title">
            Ethan
            <span class="line-accent">Reimann</span>
          </h1>
          <p class="hero-body">
            Hello World! I'm a 10th grade student in the United States.
            This is one of my many attempts at a website in this modern
            world where personal websites are very uncommon. You can find
            me and my work all across the internet — YouTube, GitHub, and
            right here. This site is home base for all of it.
          </p>
        </div>
        <div class="hero-stamp-wrap">
          <span class="stamp stamp-warm stamp-tilt">Est. 2009</span>
        </div>
      </div>

      <div class="tile s-photo g-portrait f f2">
        <Image class="tile-photo" src={portraitOutside} alt="Ethan Reimann outdoors" width={600} quality={88} />
      </div>

      <!-- ═══ NAV TILES ═══ -->
      <a class="tile tile-pad nav-tile s-white g-nav1 f f3" href="/photography/">
        <div>
          <span class="nav-num">01</span>
          <span class="nav-name">Photography</span>
          <span class="nav-desc">Moments through the lens</span>
        </div>
      </a>
      <a class="tile tile-pad nav-tile s-white g-nav2 f f3" href="/projects/">
        <div>
          <span class="nav-num">02</span>
          <span class="nav-name">Projects</span>
          <span class="nav-desc">Things I've built</span>
        </div>
      </a>
      <a class="tile tile-pad nav-tile s-white g-nav3 f f3" href="/blog/">
        <div>
          <span class="nav-num">03</span>
          <span class="nav-name">The Blog</span>
          <span class="nav-desc">Digital public journal</span>
        </div>
      </a>
      <a class="tile tile-pad nav-tile s-white g-nav4 f f3" href="/samling/">
        <div>
          <span class="nav-num">04</span>
          <span class="nav-name">Samling</span>
          <span class="nav-desc">The collection</span>
        </div>
      </a>

      <!-- ═══ BIO ═══ -->
      <div class="tile tile-pad s-white g-bio f f4">
        <div>
          <p class="t-label">About Me</p>
          <p class="bio-body">
            My hobbies span Theatre, Music (Vocal &amp; Composition),
            Software Engineering, 4&#8209;H, and Writing. I run
            <a href="https://reimannlabs.com/" style="color:var(--warm);text-decoration:none;font-weight:600;">Reimann Labs</a>
            and a handful of other projects.
          </p>
          <div class="bio-row">
            <span class="bio-key">Age</span>
            <span class="bio-val">16 — born July 2009</span>
          </div>
          <div class="bio-row">
            <span class="bio-key">Study</span>
            <span class="bio-val">10th Grade</span>
          </div>
          <div class="bio-row">
            <span class="bio-key">Into</span>
            <span class="bio-val">Economics, Music, Finance</span>
          </div>
          <div class="bio-row">
            <span class="bio-key">Email</span>
            <span class="bio-val"><a href="mailto:hello@ethanreimann.com">hello@ethanreimann.com</a></span>
          </div>
        </div>
      </div>

      <div class="tile s-photo g-photo1 f f4">
        <Image class="tile-photo" src={performingArts} alt="Ethan on stage" width={500} quality={82} />
        <span class="photo-label"><span class="tag">Theatre</span></span>
      </div>

      <div class="tile s-warm stat-center g-stat1 f f4">
        <div>
          <span class="stat-num" style="color:#fff;">16</span>
          <p class="stat-sub">years old</p>
        </div>
      </div>
      <div class="tile s-ink stat-center g-stat2 f f4">
        <div>
          <span class="stat-num">10th</span>
          <p class="stat-sub">Grade</p>
        </div>
      </div>

      <div class="tile s-photo g-photo2 f f5">
        <Image class="tile-photo" src={vcfmw} alt="Vintage Computer Festival Midwest" width={500} quality={82} />
        <span class="photo-label"><span class="tag tag-warm">VCFMW</span></span>
      </div>

      <div class="tile s-photo g-photo3 f f5">
        <Image class="tile-photo" src={cameraDarkmirror} alt="Ethan with camera" width={500} quality={82} />
        <span class="photo-label"><span class="tag">Photo</span></span>
      </div>

      <!-- ═══ MANIFESTO ═══ -->
      <div class="tile tile-pad s-ink g-manifesto f f5">
        <div>
          <p class="t-label">Manifesto</p>
          <p class="manifesto-text">
            "Personal websites have always felt like a lost art. I would
            rather my work be on a website owned by me rather than some
            billionaire social media platform."
          </p>
        </div>
        <div class="manifesto-footer">
          <span class="stamp stamp-light stamp-tilt">This site shall grow with time</span>
        </div>
      </div>

      <!-- ═══ BLOG ═══ -->
      <div class="tile tile-pad s-white g-blog f f6">
        <div>
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
            <p class="t-label" style="margin-bottom:0;">Latest Writing</p>
            <span class="stamp stamp-warm" style="font-size:0.5rem;transform:rotate(-1.5deg);">New</span>
          </div>
          {sortedPosts.map((post, i) => (
            <div class="blog-row">
              <span class="blog-num">{String(i + 1).padStart(2, '0')}</span>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
              </time>
            </div>
          ))}
        </div>
      </div>

      <!-- ═══ BOOKS ═══ -->
      <div class="tile tile-pad s-cream g-books f f6">
        <div>
          <p class="t-label">Bookshelf</p>
          {books.map((b) => (
            <div class="list-item">
              <span class="list-title">{b.title}</span>
              {b.active ? <span class="badge">Reading</span> : <span class="list-meta">{b.author}</span>}
            </div>
          ))}
        </div>
      </div>

      <!-- ═══ ALBUMS ═══ -->
      <div class="tile tile-pad s-ink g-albums f f7">
        <div>
          <p class="t-label">On Rotation</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.3rem 2rem;">
            {albums.map((a) => (
              <div class="list-item">
                <span class="list-title">{a.title}</span>
                <span class="list-meta">{a.artist}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</AtelierLayout>
