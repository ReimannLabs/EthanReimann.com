---
/**
 * ATELIER — Gallery / Digital Home
 */

import AtelierLayout from '../layouts/AtelierLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portraitOutside from '../images/ethan_portrait_outside.jpg';
import performingArts from '../images/ethan_performing_arts.jpg';
import vcfmw from '../images/ethan_VCFMW.jpg';
import portraitInside from '../images/ethan_new_portrait_inside.jpg';
import cameraDarkmirror from '../images/ethan_camera_darkmirror.JPG';

const rooms = [
  { name: 'Photography', href: '/photography/', icon: '&#9634;', desc: 'Moments captured through the lens' },
  { name: 'Projects', href: '/projects/', icon: '&#9648;', desc: 'Things I\'ve built and contributed to' },
  { name: 'The Blog', href: '/blog/', icon: '&#9998;', desc: 'A digital public journal' },
  { name: 'GitHub', href: 'https://github.com/ReimannLabs', icon: '&#10070;', desc: 'Open source work and code' },
];

const books = [
  { title: 'The Brothers Karamazov', author: 'Fyodor Dostoevsky', active: true },
  { title: 'The Giver', author: 'Lois Lowry' },
  { title: 'We Who Wrestle with God', author: 'Jordan Peterson' },
  { title: 'Welcome to the Universe', author: 'Neil DeGrasse Tyson, Et al.' },
  { title: 'Ghost Town Living', author: 'Brent Underwood' },
  { title: 'Too Big to Fail', author: 'Andrew Sorkin' },
  { title: 'The Order of Time', author: 'Carlo Rovelli' },
];

const albums = [
  { title: "I'm The Problem", artist: 'Morgan Wallen' },
  { title: 'From A Room: Volume 2', artist: 'Chris Stapleton' },
  { title: 'Chief', artist: 'Eric Church' },
  { title: 'Leather', artist: 'Cody Johnson' },
  { title: 'From Elvis in Memphis', artist: 'Elvis Presley' },
  { title: 'What Are We Waiting For?', artist: 'For King & Country' },
  { title: 'Jars of Clay', artist: 'Jars of Clay' },
  { title: 'Summertime Blues', artist: 'Zach Bryan' },
];

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AtelierLayout>
  <style>
    /* Hero */
    .hero {
      padding: 4rem 0;
      border-bottom: 1px solid var(--border);
    }
    .hero-greeting {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--warm);
      margin-bottom: 1em;
    }
    .hero-title {
      font-family: 'Fraunces', serif;
      font-weight: 400;
      font-size: clamp(2.2rem, 4vw + 0.8rem, 3.8rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      max-width: 600px;
    }
    .hero-title em { font-style: italic; color: var(--warm); }

    /* About with portrait */
    .intro {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 3rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--border);
      align-items: center;
    }
    @media (max-width: 640px) {
      .intro { grid-template-columns: 1fr; }
      .portrait { max-width: 260px; }
    }
    .intro p { color: var(--ink); margin-bottom: 1em; }
    .intro p:last-child { margin-bottom: 0; }
    .portrait {
      width: 100%;
      height: auto;
      border-radius: 6px;
      filter: grayscale(15%);
    }

    /* Room tiles */
    .rooms {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin: 3rem 0;
    }
    @media (max-width: 520px) { .rooms { grid-template-columns: 1fr; } }
    .room {
      background: var(--surface);
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.5em;
      transition: background 0.2s;
    }
    .room:hover { background: var(--warm-light); }
    .room-icon { font-size: 1.5rem; color: var(--warm); line-height: 1; }
    .room-name { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.05rem; }
    .room-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

    /* Callout */
    .callout {
      background: var(--warm-light);
      border-left: 3px solid var(--warm);
      padding: 1.5rem 2rem;
      margin: 3rem 0;
      border-radius: 0 6px 6px 0;
    }
    .callout strong { font-family: 'Fraunces', serif; display: block; margin-bottom: 0.3em; font-size: 0.95rem; }
    .callout p { color: var(--muted); font-size: 0.9rem; }

    /* Lists */
    .lists {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 3rem 0;
      border-bottom: 1px solid var(--border);
    }
    @media (max-width: 640px) { .lists { grid-template-columns: 1fr; gap: 2rem; } }
    .list-section h2 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .list-section ul { list-style: none; }
    .list-section li {
      padding: 0.4em 0;
      font-size: 0.9rem;
      display: flex;
      justify-content: space-between;
      gap: 1em;
      border-bottom: 1px solid var(--bg);
    }
    .list-section li:last-child { border-bottom: none; }
    .list-title { color: var(--ink); }
    .list-meta { color: var(--muted); font-size: 0.82em; text-align: right; white-space: nowrap; }
    .badge {
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--warm);
      background: var(--warm-light);
      padding: 0.15em 0.6em;
      border-radius: 3px;
    }

    /* Bio */
    .bio { padding: 3rem 0; border-bottom: 1px solid var(--border); }
    .bio h2 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .bio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
    @media (max-width: 640px) { .bio-grid { grid-template-columns: 1fr; } }
    .bio-list { display: flex; flex-direction: column; gap: 0; }
    .bio-row { display: flex; gap: 1.5rem; padding: 0.65em 0; border-bottom: 1px solid var(--bg); }
    .bio-row:last-child { border-bottom: none; }
    .bio-row dt {
      font-weight: 600; font-size: 0.82rem; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--warm); min-width: 80px; flex-shrink: 0; padding-top: 0.1em;
    }
    .bio-row dd { font-size: 0.9rem; color: var(--ink); }
    .bio-row dd a { color: var(--warm); text-decoration: none; }
    .bio-row dd a:hover { text-decoration: underline; }
    .bio-note { color: var(--muted); font-size: 0.82em; }
    .bio-photos { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    .bio-photo {
      width: 100%; height: auto; aspect-ratio: 4/3; object-fit: cover;
      border-radius: 6px; filter: grayscale(10%); transition: filter 0.3s;
    }
    .bio-photo:hover { filter: grayscale(0%); }

    /* Blog */
    .blog { padding: 3rem 0; }
    .blog h2 {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--border);
    }
    .blog-note { color: var(--muted); font-size: 0.85rem; font-style: italic; margin-bottom: 1em; }
    .blog-item { display: flex; justify-content: space-between; align-items: baseline; padding: 0.6em 0; }
    .blog-item a { color: var(--ink); text-decoration: none; font-weight: 500; transition: color 0.2s; }
    .blog-item a:hover { color: var(--warm); }
    .blog-item time { color: var(--muted); font-size: 0.82rem; }
  </style>

  <section class="hero f f2">
    <p class="hero-greeting">Welcome to my corner of the internet</p>
    <h1 class="hero-title">This is <em>my digital home</em> — come on in.</h1>
  </section>

  <section class="intro f f3">
    <div>
      <p>
        Hello World! I'm Ethan Reimann, a 10th grade student in the United
        States. This is one of my many attempts at a website in this modern
        world where personal websites are very uncommon.
      </p>
      <p>
        You can find me and my work all across the internet — everything from
        YouTube videos to contributions to various GitHub projects. This site
        is the home base for all of it.
      </p>
    </div>
    <Image class="portrait" src={portraitOutside} alt="Ethan Reimann outdoors" width={600} quality={85} />
  </section>

  <div class="rooms f f4">
    {rooms.map((room) => (
      <a class="room" href={room.href}>
        <span class="room-icon" set:html={room.icon} />
        <span class="room-name">{room.name}</span>
        <span class="room-desc">{room.desc}</span>
      </a>
    ))}
  </div>

  <section class="bio f f5">
    <h2>Bio</h2>
    <div class="bio-grid">
      <div class="bio-details">
        <dl class="bio-list">
          <div class="bio-row">
            <dt>Age</dt>
            <dd>16 <span class="bio-note">— born July 2009</span></dd>
          </div>
          <div class="bio-row">
            <dt>Education</dt>
            <dd>10th Grade Student<br/><span class="bio-note">Interested in pursuing a degree in Economics, Music, or Finance</span></dd>
          </div>
          <div class="bio-row">
            <dt>Email</dt>
            <dd><a href="mailto:hello@ethanreimann.com">hello@ethanreimann.com</a></dd>
          </div>
          <div class="bio-row">
            <dt>Hobbies</dt>
            <dd>Theatre, Music <span class="bio-note">(Vocal &amp; Composition)</span>, Software Engineering, 4‑H, Writing</dd>
          </div>
        </dl>
      </div>
      <div class="bio-photos">
        <Image class="bio-photo" src={performingArts} alt="Ethan on stage in a Dare to Dream theatre production" width={450} quality={80} />
        <Image class="bio-photo" src={vcfmw} alt="Ethan at the Vintage Computer Festival Midwest" width={450} quality={80} />
        <Image class="bio-photo" src={portraitInside} alt="Moody indoor portrait" width={450} quality={80} />
        <Image class="bio-photo" src={cameraDarkmirror} alt="Ethan with camera" width={450} quality={80} />
      </div>
    </div>
  </section>

  <div class="callout f f5">
    <strong>Why Have a Personal Website in the 2020s?</strong>
    <p>
      Personal websites have always felt like a lost art. I would rather my work
      be on a website owned by me rather than some billionaire social media platform.
      This site shall grow with time.
    </p>
  </div>

  <div class="lists f f5">
    <div class="list-section">
      <h2>Recent Books</h2>
      <ul>
        {books.map((b) => (
          <li>
            <span class="list-title">{b.title}</span>
            {b.active ? <span class="badge">Reading</span> : <span class="list-meta">{b.author}</span>}
          </li>
        ))}
      </ul>
    </div>
    <div class="list-section">
      <h2>Favorite Albums</h2>
      <ul>
        {albums.map((a) => (
          <li>
            <span class="list-title">{a.title}</span>
            <span class="list-meta">{a.artist}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <section class="blog f f6" id="blog">
    <h2>The Blog</h2>
    <p class="blog-note">
      No set purpose — a digital public journal. Random posts, random topics.
    </p>
    {sortedPosts.map((post) => (
      <div class="blog-item">
        <a href={`/blog/${post.id}/`}>{post.data.title}</a>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </time>
      </div>
    ))}
  </section>
</AtelierLayout>
