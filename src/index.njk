---
layout: base.njk
pagination:
  data: collections.posts
  size: 6
  alias: posts
permalink: "/index.html"
---

<section class="site-hero site-hero--fullwidth py-7">
  <div class="site-hero__inner container-limited text-center">
    <h1 class="hero-title">Thoughts, experiments, and tutorials</h1>
    <p class="lead hero-lead">A personal blog by Ethan Reimann — coding, design, and life on the web.</p>
    <div class="mt-3">
      <a href="#" class="btn btn-primary btn-lg">Subscribe</a>
    </div>
  </div>
</section>

<div class="row">
  <div class="col-lg-8">
    <div class="row g-4">
      {% if posts and posts | length > 0 %}
      {% for post in posts %}
      <article class="col-12">
        <div class="card">
          {% if post.data.heroImage %}
          <img src="{{ post.data.heroImage }}" class="card-img-top" alt="{{ post.data.title }}">
          {% endif %}
          <div class="card-body">
            <h2 class="card-title">{{ post.data.title }}</h2>
            <p class="text-muted small">{{ post.date | date("MMM d, yyyy") }} · {{ post.data.readingTime | default("") }}</p>
            <p class="card-text">{{ post.data.description }}</p>
            {% if post.data.tags and post.data.tags | length > 0 %}
            <p class="mt-2">
              {% for t in post.data.tags %}
              <a class="badge custom-tag text-decoration-none me-1" href="/tags/{{ t | slug }}/">{{ t }}</a>
              {% endfor %}
            </p>
            {% endif %}
            <a href="{{ post.url }}" class="btn btn-outline-primary">Read more</a>
          </div>
        </div>
      </article>
      {% endfor %}
      {% else %}
      <div class="col-12">
        <div class="alert alert-secondary">No posts yet — add Markdown files to <code>src/posts/</code>.</div>
      </div>
      {% endif %}
    </div>
  </div>

  <aside class="col-lg-4">
    <div class="sticky-top pt-4">
      <div class="mb-4 p-3 bg-white border rounded">
        <h5>About</h5>
        <p class="mb-0">Hi, I'm Ethan. I write about web performance, design systems, and developer tools.</p>
      </div>

      <div class="mb-4 p-3 bg-white border rounded">
        <h5>Categories</h5>
        <ul class="list-unstyled mb-0">
          {% for tag in collections.tagList %}
          <li><a href="/tags/{{ tag | slug }}/">{{ tag }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="mb-4 p-3 bg-white border rounded">
        <h5>Subscribe</h5>
        <form>
          <div class="mb-2">
            <label class="visually-hidden" for="emailInput">Email address</label>
            <input id="emailInput" class="form-control" placeholder="you@example.com" type="email">
          </div>
          <button class="btn btn-primary w-100">Subscribe</button>
        </form>
      </div>

    </div>
  </aside>
</div>
