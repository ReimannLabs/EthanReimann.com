---
layout: base.njk
---

<article class="mx-auto" style="max-width:900px;">
  <header class="mb-4">
    <h1>Tags</h1>
    <p class="text-muted">Browse posts by topic.</p>
  </header>

  <section>
    <div class="row">
      {% for tag in collections.tagList %}
      <div class="col-md-4 mb-3">
        <a class="d-block p-3 bg-white border rounded text-decoration-none" href="/tags/{{ tag | slug }}/">
          <strong>{{ tag }}</strong>
        </a>
      </div>
      {% endfor %}
    </div>
  </section>
</article>
